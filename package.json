{
  "name": "22-strong-foundation-site",
  "type": "module",
  "version": "0.1.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "check": "npm run lint && npm test && npm run check-templates && npm run check-content && npm run test:hygiene && npm run test:launch && npm run build",
    "check-templates": "node scripts/check-templates.mjs",
    "check-content": "node scripts/check-home-content.mjs",
    "test:hygiene": "node scripts/check-external-calls.mjs && node scripts/check-csp.mjs && node scripts/check-anchors.mjs && node scripts/check-assets.mjs && node scripts/check-dead-code.mjs",
    "test:launch": "node scripts/check-launch-content.mjs",
    "test:e2e": "playwright test",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint src --ext .ts,.astro",
    "lint:fix": "eslint src --ext .ts,.astro --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^6.3.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "eslint": "^10.5.0",
    "eslint-plugin-astro": "^2.0.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  }
}
