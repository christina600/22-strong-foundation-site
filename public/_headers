## Security headers applied to every page by Netlify.
## These tell visitors' browsers to enforce extra protections.

/*
  # Only allow scripts/styles/fonts from your own domain.
  # Inline scripts are pinned by SHA-256 hash instead of 'unsafe-inline':
  # only the two exact snippets Astro emits (the "js" class toggle and the
  # story-video player) may run, so anything injected is blocked.
  # If a snippet changes, `npm run test:dist` fails and prints the new hash.
  Content-Security-Policy: default-src 'self'; script-src 'self' 'sha256-/x7W7R75k8Roq0WaVRQX9blP4OufE5xbAdzklGxsgpw=' 'sha256-QjH7AQm57AxEgQJ5JVbl7PmD9rdhOvvu398cAZgEnII='; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data:; connect-src 'self'; object-src 'none'; frame-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

  # Prevent browsers from guessing file types (MIME sniffing).
  X-Content-Type-Options: nosniff

  # Block your site from being embedded in iframes on other sites
  # (prevents clickjacking attacks).
  X-Frame-Options: DENY

  # Always use HTTPS. The "max-age" is 1 year in seconds.
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Restrict browser features you don't use (camera, mic, location, etc.).
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()

  # Don't send the full page URL when visitors click links to other sites.
  Referrer-Policy: no-referrer

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/images/*
  Cache-Control: public, max-age=31536000, immutable

/video/*
  Cache-Control: public, max-age=31536000, immutable
