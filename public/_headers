## Security headers — applied to every page by Netlify.
## These tell visitors' browsers to enforce extra protections.

/*
  # Only allow scripts/styles/fonts from your own domain.
  # 'unsafe-inline' is needed because Astro inlines small scripts
  # and View Transitions use inline styles.
  # frame-src allows the YouTube testimonial embed (privacy-friendly
  # youtube-nocookie domain). If you remove the video, you can drop it.
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; frame-src https://www.youtube-nocookie.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

  # Prevent browsers from guessing file types (MIME sniffing).
  X-Content-Type-Options: nosniff

  # Block your site from being embedded in iframes on other sites
  # (prevents clickjacking attacks).
  X-Frame-Options: DENY

  # Always use HTTPS. The "max-age" is 1 year in seconds.
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Restrict browser features you don't use (camera, mic, location, etc.).
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()

  # Don't send the full page URL when visitors click links to other sites.
  Referrer-Policy: no-referrer
