---
/**
 * Newsletter page.
 */

import Page from "../layouts/Page.astro";
import NewsletterSignup from "../components/sections/NewsletterSignup.astro";
import DonatePreview from "../components/sections/DonatePreview.astro";
import ContactPreview from "../components/sections/ContactPreview.astro";

import pageData from "../content/pages/newsletter.json";
---

<Page
  title={pageData.label}
  eyebrow={pageData.eyebrow}
  headline={pageData.title}
  intro={pageData.intro}
  currentPage="get-involved"
  description={pageData.metaDescription}
  ogImage={pageData.ogImage}
>
  <NewsletterSignup />
  <DonatePreview />
  <ContactPreview />
</Page>
