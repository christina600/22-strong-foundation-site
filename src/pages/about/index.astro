---
import HomeBase from "../../layouts/HomeBase.astro";
import AboutIntroSection from "../../components/sections/AboutIntroSection.astro";
import FeaturedPublications from "../../components/sections/FeaturedPublications.astro";
import InstitutionalLayerSection from "../../components/sections/InstitutionalLayerSection.astro";
import LeadershipSection from "../../components/sections/LeadershipSection.astro";
import SectionCta from "../../components/sections/SectionCta.astro";
import SiteFooter from "../../components/sections/SiteFooter.astro";
import SiteHeader from "../../components/sections/SiteHeader.astro";
import home from "../../content/home.json";

const description = "Meet the founders and leadership behind 22Strong Foundation.";
const intro = {
  eyebrow: "About 22Strong",
  heading: home.story.heading,
  lead: home.heroLead,
  paragraphs: home.story.paragraphs,
  proof: home.credibility,
  image: {
    src: "/images/about-care.jpg",
    alt: "Hands-on knee treatment during a recovery session.",
    caption: "Built inside real recovery care in Newport Beach.",
    position: "50% 38%",
  },
};
---

<HomeBase title="About 22Strong Foundation." description={description}>
  <div class="site site--about">
    <SiteHeader current="about" />

    <main id="main" class="about-page">
      <AboutIntroSection {...intro} />
      <FeaturedPublications publications={home.press.publications} heading={home.press.heading} />
      <LeadershipSection people={home.leadership} headingLevel="h2" />
      <SectionCta
        variant="teal"
        text="Interested in volunteering for 22Strong?"
        label="Contact us"
        href="/#contact"
      />
      <InstitutionalLayerSection governance={home.governance} />
      <SectionCta
        text="Keep the next visit within reach."
        label="Fund recovery care"
        href="/#donate"
      />
    </main>

    <SiteFooter footer={home.footer} homeHrefPrefix="/" />
  </div>
</HomeBase>
