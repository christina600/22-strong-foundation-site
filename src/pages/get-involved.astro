---
/**
 * Get Involved page.
 */

import Page from "../layouts/Page.astro";
import InvolvementGrid from "../components/sections/InvolvementGrid.astro";
import VolunteerRoles from "../components/sections/VolunteerRoles.astro";
import TrainingPreview from "../components/sections/TrainingPreview.astro";
import DonatePreview from "../components/sections/DonatePreview.astro";
import ContactPreview from "../components/sections/ContactPreview.astro";

import pageData from "../content/pages/get-involved.json";
---

<Page
  title={pageData.label}
  eyebrow={pageData.eyebrow}
  headline={pageData.title}
  intro={pageData.intro}
  currentPage="get-involved"
  description={pageData.metaDescription}
  ogImage={pageData.ogImage}
>
  <InvolvementGrid />
  <VolunteerRoles />
  <TrainingPreview />
  <DonatePreview />
  <ContactPreview />
</Page>
