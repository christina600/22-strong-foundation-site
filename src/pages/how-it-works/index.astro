---
import HomeBase from "../../layouts/HomeBase.astro";
import SiteFooter from "../../components/sections/SiteFooter.astro";
import SiteHeader from "../../components/sections/SiteHeader.astro";
import TestimonialVideo from "../../components/sections/TestimonialVideo.astro";
import home from "../../content/home.json";

const description = "How 22STRONG closes the recovery gap — from referral to continued care.";
---

<HomeBase title="How It Works" description={description}>
  <div class="site site--about">
    <SiteHeader current="how-it-works" />

    <main id="main" class="about-page how-page">
      <section class="how-page-hero" aria-labelledby="how-title">
        <div class="how-page-hero__inner">
          <p class="eyebrow">How it works</p>
          <h1 id="how-title">
            <span>A&nbsp;recovery&nbsp;gap appears.</span>
            <span>22STRONG closes it.</span>
          </h1>
          <p class="lead">
            A referral comes in. We check that the coverage gap is real. Donor money pays
            for the next session. That's the whole model.
          </p>
        </div>
      </section>

      <div class="how-page-flow">
        <section class="how-context" aria-labelledby="the-gap">
          <p class="how-context__label">The gap</p>
          <h2 id="the-gap">Coverage ends before recovery does.</h2>
          <p>
            A person is mid-recovery when insurance runs out or VA approval stalls. The
            treatment plan is still good; the money behind it is gone. Donor funding pays
            for the visits in between.
          </p>
        </section>

        <ol class="how-process" aria-label="22STRONG care funding path">
          <li class="how-step">
            <div class="how-step__rail" aria-hidden="true">
              <span class="how-step__dot">1</span>
            </div>
            <div class="how-step__body">
              <p class="how-step__label">Step 1</p>
              <h2>Referral or request</h2>
              <p>
                Referrals come from the VA, veteran networks, coaches, school counselors,
                and community organizations. People can also request care for themselves.
              </p>
              <figure class="how-step__media">
                <img
                  src="/images/referral-conversation.jpg"
                  alt="Two veterans in conversation at home."
                  loading="lazy"
                />
                <figcaption>Most referrals start with a conversation.</figcaption>
              </figure>
            </div>
          </li>

          <li class="how-step">
            <div class="how-step__rail" aria-hidden="true">
              <span class="how-step__dot">2</span>
            </div>
            <div class="how-step__body">
              <p class="how-step__label">Step 2</p>
              <h2>Gap review</h2>
              <p>
                22STRONG checks that there's a real treatment plan and that the money
                behind it has actually run out. If it has, we fund the care.
              </p>
              <figure class="how-photo-placeholder" aria-label="Photo needed for the gap review step">
                <div class="how-photo-placeholder__frame">
                  <span>Photo needed</span>
                  <p>Referral or care-plan review, with no private patient details visible.</p>
                </div>
              </figure>
            </div>
          </li>

          <li class="how-step">
            <div class="how-step__rail" aria-hidden="true">
              <span class="how-step__dot">3</span>
            </div>
            <div class="how-step__body">
              <p class="how-step__label">Step 3</p>
              <h2>Care funded</h2>
              <p>22STRONG pays the clinic directly. The patient never sees a bill and never handles the money.</p>
              <figure class="how-photo-placeholder" aria-label="Photo needed for the care funded step">
                <div class="how-photo-placeholder__frame">
                  <span>Photo needed</span>
                  <p>Funding handoff, front desk moment, or care invoice approval without personal information.</p>
                </div>
              </figure>
            </div>
          </li>

          <li class="how-step how-step--care">
            <div class="how-step__rail" aria-hidden="true">
              <span class="how-step__dot">4</span>
            </div>
            <div class="how-step__body">
              <p class="how-step__label">Step 4</p>
              <h2>Care provided</h2>
              <p>
                Sessions happen at Next Level Fitness & Wellness Center in Newport Beach.
                Funded care can include Fascial Integrative Treatment (FIT) and hands-on
                work on rotator cuff, knee, neck, lower back, hip, ankle and foot, and
                wrist and elbow injuries.
              </p>
              <p>
                FIT is Next Level's own hands-on method. It works on the connective tissue
                around muscles and joints to restore movement, often in fewer sessions than
                traditional care.
              </p>
              <p>
                Next Level is co-owned by 22STRONG's founders.
                <a href="/transparency/">Read how we manage that relationship</a>.
              </p>
              <figure class="how-step__media">
                <img
                  src="/images/story-veteran-leg-therapy.webp"
                  alt="Dr. Chris treating a veteran's leg at Next Level Wellness Center."
                  loading="lazy"
                />
                <figcaption>Where the funding turns into care: hands-on recovery treatment at Next Level.</figcaption>
              </figure>
            </div>
          </li>

          <li class="how-step">
            <div class="how-step__rail" aria-hidden="true">
              <span class="how-step__dot">5</span>
            </div>
            <div class="how-step__body">
              <p class="how-step__label">Step 5</p>
              <h2>Follow-through</h2>
              <p>
                One visit rarely finishes a recovery plan. 22STRONG funds the follow-up
                sessions too, until coverage resumes or the plan is complete.
                <span class="how-stat-note">So far that's 200+ funded sessions for 45 people.</span>
              </p>
              <TestimonialVideo
                class="how-testimonial how-testimonial--billy"
                src="/video/billy-testimonial.mp4"
                poster="/images/billy-poster.webp"
                playLabel="Play Billy's veteran story"
                attribution="Billy · Veteran"
                quote="Sometimes the VA kind of lags on services… I've been treated without referrals until the VA sends a referral… my health has improved significantly."
                tone="light"
                layout="inline"
              />
            </div>
          </li>
        </ol>

        <div class="how-boundaries" aria-label="Funding boundaries">
          <section class="how-boundary" aria-labelledby="what-we-fund">
            <p class="how-context__label">What we fund</p>
            <h2 id="what-we-fund">We fund hands-on recovery care. Nothing else.</h2>
            <ul>
              <li>Chiropractic care</li>
              <li>Physical therapy</li>
              <li>Massage therapy</li>
              <li>Fascial Integrative Treatment (FIT)</li>
              <li>Follow-through after the first visit</li>
            </ul>
            <p class="how-fund-cost">One session costs $190.</p>
          </section>

          <section class="how-boundary how-boundary--limits" aria-labelledby="what-we-dont">
            <p class="how-context__label">What 22STRONG does not provide</p>
            <h2 id="what-we-dont">That rules out:</h2>
            <ul>
              <li>Emergency medical care</li>
              <li>Medical diagnosis</li>
              <li>Insurance advice</li>
              <li>Direct cash payments to individuals</li>
            </ul>
          </section>
        </div>

        <section class="how-care-voice" aria-labelledby="care-in-their-words">
          <p class="how-context__label">Care in their words</p>
          <h2 id="care-in-their-words">What continued care feels like.</h2>
          <TestimonialVideo
            class="how-testimonial how-testimonial--care"
            src="/video/veteran-experience-testimonial.mp4"
            poster="/images/veteran-experience-poster.webp"
            playLabel="Play a veteran's recovery care experience"
            attribution="Veteran · Next Level Wellness"
            quote="The physical therapy mixed with the chiropractic sessions really is a game changer."
            tone="light"
            layout="inline"
          />
        </section>

        <section class="how-referral" aria-labelledby="refer-someone">
          <p class="how-context__label">Refer someone</p>
          <h2 id="refer-someone">Know someone whose recovery care is at risk?</h2>
          <p>Start a referral. It takes a few minutes and doesn't commit them to anything.</p>
          <a class="pill primary" href="/#contact">Start a referral</a>
          <a class="how-referral__alt" href="/#donate">or fund recovery care</a>
          <figure class="how-referral__voice">
            <img
              src="/images/tom-boscamp.jpg"
              alt="Tom Boscamp"
              width="400"
              height="400"
              loading="lazy"
              decoding="async"
            />
            <blockquote>
              <p>
                "The VA treatments are far and few between as they do not have enough
                chiropractors, massage therapists, and Physical therapy specialists.
                Thankfully Dr. Vas has filled that void and with his treatments it has
                allowed me to continue being active."
              </p>
              <cite>Tom Boscamp · U.S. Army Veteran · Veteran Services Coordinator</cite>
            </blockquote>
          </figure>
        </section>
      </div>
    </main>

    <SiteFooter footer={home.footer} homeHrefPrefix="/" />
  </div>
</HomeBase>
