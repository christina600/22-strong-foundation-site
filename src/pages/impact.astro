---
/**
 * Impact page.
 */

import Page from "../layouts/Page.astro";
import ImpactMetrics from "../components/sections/ImpactMetrics.astro";
import ImpactDeep from "../components/sections/ImpactDeep.astro";
import RevenueExpenseBreakdown from "../components/sections/RevenueExpenseBreakdown.astro";
import AccountabilityCards from "../components/sections/AccountabilityCards.astro";
import DonatePreview from "../components/sections/DonatePreview.astro";

import pageData from "../content/pages/impact.json";
---

<Page
  title={pageData.label}
  eyebrow={pageData.eyebrow}
  headline={pageData.title}
  intro={pageData.intro}
  currentPage="impact"
  description={pageData.metaDescription}
  ogImage={pageData.ogImage}
>
  <ImpactMetrics />
  <ImpactDeep />
  <RevenueExpenseBreakdown />
  <AccountabilityCards />
  <DonatePreview />
</Page>
