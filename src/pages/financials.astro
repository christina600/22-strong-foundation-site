---
/**
 * Financials — consolidated donor-trust & transparency page (under About Us).
 * Merges impact reports, where-your-money-goes, IRS filings & disclosures,
 * third-party ratings, and the Donor Bill of Rights into one place so donor
 * proof lives within one click of every donation page.
 */

import Page from "../layouts/Page.astro";
import ImpactReports from "../components/sections/ImpactReports.astro";
import ImpactDeep from "../components/sections/ImpactDeep.astro";
import BuiltToExecute from "../components/sections/BuiltToExecute.astro";
import RevenueExpenseBreakdown from "../components/sections/RevenueExpenseBreakdown.astro";
import FinancialDisclosureFull from "../components/sections/FinancialDisclosureFull.astro";
import TransparencySeals from "../components/sections/TransparencySeals.astro";
import PolicyPlaceholder from "../components/sections/PolicyPlaceholder.astro";

import pageData from "../content/pages/financials.json";
---

<Page
  title={pageData.label}
  eyebrow={pageData.eyebrow}
  headline={pageData.title}
  intro={pageData.intro}
  currentPage="about"
  description={pageData.metaDescription}
  ogImage={pageData.ogImage}
>
  <ImpactReports />
  <ImpactDeep />
  <BuiltToExecute />
  <RevenueExpenseBreakdown />
  <FinancialDisclosureFull />
  <TransparencySeals />
  <div id="donor-rights">
    <PolicyPlaceholder policyLabel="Donor Bill of Rights" />
  </div>
</Page>
