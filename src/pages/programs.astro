---
/**
 * Programs page.
 */

import Page from "../layouts/Page.astro";
import ProgramGrid from "../components/sections/ProgramGrid.astro";
import ProgramPillars from "../components/sections/ProgramPillars.astro";
import StabilityPipeline from "../components/sections/StabilityPipeline.astro";
import Testimonials from "../components/sections/Testimonials.astro";
import DonatePreview from "../components/sections/DonatePreview.astro";

import pageData from "../content/pages/programs.json";
---

<Page
  title={pageData.label}
  eyebrow={pageData.eyebrow}
  headline={pageData.title}
  intro={pageData.intro}
  actions={pageData.actions}
  currentPage="programs"
  description={pageData.metaDescription}
  ogImage={pageData.ogImage}
>
  <ProgramGrid />
  <ProgramPillars />
  <StabilityPipeline />
  <Testimonials />
  <DonatePreview />
</Page>
