---
/**
 * Homepage — the site as one continuous recovery story.
 *
 * Each component below has a single editorial job:
 * conflict, proof, origin, audience stakes, care path, donor action.
 */

import HomeBase from "../layouts/HomeBase.astro";
import AudienceSection from "../components/sections/AudienceSection.astro";
import ContactSection from "../components/sections/ContactSection.astro";
import CredibilityStrip from "../components/sections/CredibilityStrip.astro";
import DonationAskSection from "../components/sections/DonationAskSection.astro";
import GivingInvite from "../components/sections/GivingInvite.astro";
import FeaturedPublications from "../components/sections/FeaturedPublications.astro";
import HeroSection from "../components/sections/HeroSection.astro";
import LeadershipSection from "../components/sections/LeadershipSection.astro";
import NarrativeScene from "../components/sections/NarrativeScene.astro";
import ServicePathSection from "../components/sections/ServicePathSection.astro";
import SiteFooter from "../components/sections/SiteFooter.astro";
import StrongCircleSection from "../components/sections/StrongCircleSection.astro";
import TestimonialsSection from "../components/sections/TestimonialsSection.astro";
import home from "../content/home.json";
import { buildAudienceGroups } from "../utils/home-story";

const audienceGroups = buildAudienceGroups(home);
---

<HomeBase title="Fund recovery care when the system stops short.">
  <div class="site">
    <header>
      <nav class="nav" aria-label="Main navigation">
        <a class="brand" href="#top">22 Strong Foundation</a>
        <div class="nav-links" aria-label="Section navigation">
          <a href="#about">About</a>
          <a href="#serve">Who we serve</a>
          <a href="#how-it-works">How it works</a>
          <a href="#strong-circle">Strong Circle</a>
        </div>
        <div class="nav-actions">
          <a class="pill primary" href="#donate">Donate</a>
          <a class="pill" href="#contact">Contact</a>
        </div>
      </nav>
    </header>

    <main id="main">
      <HeroSection hero={home.hero} />
      <CredibilityStrip facts={home.credibility} lead={home.hero.lead} />

      <AudienceSection chapter="01" introTitle="Who we serve" groups={audienceGroups} />

      <NarrativeScene
        chapter="02"
        id="about"
        eyebrow={home.mission.eyebrow}
        heading={home.mission.heading}
        lead={home.mission.lead}
        evidenceStats={home.stats.others}
        evidenceAriaLabel="Evidence of the recovery access gap"
        needParagraphs={home.mission.needParagraphs}
      />

      <NarrativeScene
        chapter="03"
        id="story"
        eyebrow={home.story.eyebrow}
        heading={home.story.heading}
        paragraphs={home.story.paragraphs}
      />

      <ServicePathSection chapter="04" content={home.howItWorks} />
      <TestimonialsSection groups={audienceGroups} />
      <FeaturedPublications chapter="05" publications={home.press.publications} />
      <LeadershipSection people={home.leadership} />
      <StrongCircleSection chapter="06" strongCircle={home.strongCircle} />
      <DonationAskSection chapter="07" donate={home.donate} />
      <ContactSection contact={home.contact} />
    </main>

    <SiteFooter footer={home.footer} />
    <GivingInvite />
  </div>
</HomeBase>
