---
// Holding page — temporary "launching soon" page for the public domain.
// The full site lives on the `main` branch and launches later.
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>22STRONG Foundation — Launching This Summer</title>
<meta name="description" content="22STRONG Foundation funds recovery care for veterans and low-income youth when coverage runs out. Our new site is launching this summer.">
<meta name="robots" content="noindex">
<link rel="icon" href="/favicon.svg" type="image/svg+xml">
<style>
  /* Self-hosted fonts (latin subset) — no request to Google, and our CSP
     (font-src 'self') actually allows these, unlike the old Google Fonts
     link it silently blocked. Files live in public/fonts/. */
  @font-face{font-family:'Barlow';font-style:normal;font-weight:400;font-display:swap;src:url('/fonts/barlow-400.woff2') format('woff2');unicode-range:U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD}
  @font-face{font-family:'Barlow';font-style:normal;font-weight:500;font-display:swap;src:url('/fonts/barlow-500.woff2') format('woff2');unicode-range:U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD}
  @font-face{font-family:'Barlow';font-style:normal;font-weight:600;font-display:swap;src:url('/fonts/barlow-600.woff2') format('woff2');unicode-range:U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD}
  @font-face{font-family:'Barlow';font-style:normal;font-weight:700;font-display:swap;src:url('/fonts/barlow-700.woff2') format('woff2');unicode-range:U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD}
  @font-face{font-family:'Barlow Condensed';font-style:normal;font-weight:600;font-display:swap;src:url('/fonts/barlow-condensed-600.woff2') format('woff2');unicode-range:U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD}
  @font-face{font-family:'Barlow Condensed';font-style:normal;font-weight:800;font-display:swap;src:url('/fonts/barlow-condensed-800.woff2') format('woff2');unicode-range:U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD}
  :root{
    --paper:#f8f4eb; --cream:#f3eee2; --muted:rgba(243,238,226,.64);
    --orange:#b95524; --orange-dark:#863a1a; --bg:#1b1f1b; --line:rgba(243,238,226,.14);
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html,body{height:100%}
  body{
    background:var(--bg); color:var(--cream);
    font-family:"Barlow",system-ui,sans-serif;
    min-height:100vh; display:flex; align-items:center; justify-content:center;
    padding:3vh 24px; text-align:center; -webkit-font-smoothing:antialiased;
  }
  .wrap{max-width:720px; display:flex; flex-direction:column; align-items:center}
  .mark{display:flex; flex-direction:column; align-items:center; line-height:.9; margin-bottom:22px}
  .mark .wordmark{display:inline-flex; align-items:baseline; gap:.01em; font-family:"Barlow Condensed",sans-serif; font-weight:800; font-size:clamp(3.6rem,12vw,6.8rem); letter-spacing:0}
  .mark .wordmark-22{color:#d35f28; text-shadow:0 0 16px rgba(211,95,40,.24)}
  .mark .wordmark-strong{color:var(--cream)}
  .mark .bar{width:92px; height:7px; background:var(--orange); margin:12px 0 9px; border-radius:2px}
  .mark .foundation{font-family:"Barlow Condensed",sans-serif; font-weight:600; font-size:clamp(1rem,3vw,1.35rem); letter-spacing:.46em; color:var(--cream)}
  .eyebrow{font-weight:600; font-size:1.2rem; letter-spacing:.26em; text-transform:uppercase; color:rgba(243,238,226,.52); margin-bottom:14px}
  .tagline{font-weight:600; font-size:clamp(1.55rem,3.1vw,2.25rem); line-height:1.22; max-width:24ch; margin-bottom:32px; text-wrap:balance}
  .cta{display:inline-block; font-family:"Barlow",sans-serif; font-weight:700; font-size:1.2rem;
    letter-spacing:.02em; color:var(--bg); background:var(--cream); border:1px solid rgba(243,238,226,.32); cursor:pointer;
    padding:17px 38px; border-radius:8px; text-decoration:none; box-shadow:0 10px 26px rgba(0,0,0,.18);
    transition:background .18s ease, border-color .18s ease, transform .18s ease}
  .cta:hover{background:var(--paper); border-color:rgba(243,238,226,.72); transform:translateY(-1px)}
  .meta{margin-top:26px; padding-top:20px; border-top:1px solid var(--line); width:100%; max-width:600px;
    font-size:1.05rem; letter-spacing:.02em; color:var(--muted); line-height:1.85}
  .meta a{color:var(--cream); text-decoration:none; border-bottom:1px solid var(--line)}
  .meta .dot{opacity:.4; padding:0 10px}

  .hp{position:absolute; left:-9999px}
  .sr{position:absolute; width:1px; height:1px; overflow:hidden; clip:rect(0,0,0,0)}
  .notify-label{font-weight:600; font-size:.95rem; letter-spacing:.16em; text-transform:uppercase;
    color:rgba(243,238,226,.52); margin-bottom:14px}
  .notify-form{display:flex; flex-wrap:wrap; justify-content:center; gap:12px}
  .notify-form[hidden]{display:none}
  .notify-form input[type="email"]{
    font-family:"Barlow",sans-serif; font-size:1.1rem; color:var(--cream);
    background:rgba(243,238,226,.06); border:1px solid rgba(243,238,226,.28);
    border-radius:8px; padding:15px 20px; min-width:240px; outline:none;
    transition:border-color .18s ease, background .18s ease;
  }
  .notify-form input[type="email"]::placeholder{color:rgba(243,238,226,.4)}
  .notify-form input[type="email"]:focus{border-color:var(--orange); background:rgba(243,238,226,.1)}
  .notify-success{font-weight:600; font-size:1.2rem; color:var(--cream); margin-bottom:0}

  /* Mobile: cinematic "trailer" hero. The 22STRONG Foundation mark dominates
     the screen, "Launching this summer" is the kicker, and the sentence + sign-up
     support quietly beneath it. This is the most-shared view, so it leads big. */
  @media (max-width:520px){
    body{padding:5vh 22px}
    .mark{margin-bottom:24px; line-height:.86}
    .mark .wordmark{font-size:18vw}
    .mark .bar{width:58px; height:6px; margin:18px 0 13px}
    .mark .foundation{font-size:4.4vw; letter-spacing:.42em}
    .eyebrow{font-size:3.6vw; letter-spacing:.26em; color:rgba(243,238,226,.92); margin-bottom:0}
    .tagline{font-size:1.05rem; font-weight:500; line-height:1.5; color:var(--muted);
      max-width:30ch; margin:24px auto 34px}
    .notify-label{font-size:.78rem; letter-spacing:.16em; margin-bottom:16px}
    .notify-form{flex-direction:column; align-items:center; gap:14px; width:100%; max-width:300px; margin:0 auto}
    .notify-form input[type="email"]{min-width:0; width:100%; text-align:center; font-size:1rem; padding:14px 18px}
    .notify-form .cta{width:auto; align-self:center; font-size:1rem; padding:13px 38px}
    .meta{font-size:.88rem; line-height:1.7; letter-spacing:0}
    .meta a, .meta .loc{display:block}
    .meta .dot{display:none}
    .meta .legal{display:block; margin-top:8px; font-size:.8rem}
  }
</style>
</head>
<body>
  <main class="wrap">
    <div class="mark">
      <span class="wordmark"><span class="wordmark-22">22</span><span class="wordmark-strong">STRONG</span></span>
      <span class="bar" aria-hidden="true"></span>
      <span class="foundation">FOUNDATION</span>
    </div>
    <p class="eyebrow">Launching this summer</p>
    <h1 class="tagline">22STRONG funds hands-on recovery care for veterans and low-income youth when insurance and cost fall short.</h1>
    <p class="notify-label">Sign up to be notified</p>
    <form name="notify" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="notify-form" id="notify-form">
      <input type="hidden" name="form-name" value="notify" />
      <p class="hp"><label>Don't fill this out if you're human: <input name="bot-field" /></label></p>
      <label class="sr" for="notify-email">Email address</label>
      <input type="email" id="notify-email" name="email" placeholder="you@email.com" autocomplete="email" required />
      <button type="submit" class="cta">Notify me</button>
    </form>
    <p class="notify-success" id="notify-success" hidden>You're on the list — we'll be in touch when we launch.</p>
    <div class="meta">
      <a href="mailto:team@22strongfoundation.com">team@22strongfoundation.com</a>
      <span class="dot">·</span><span class="loc">Newport Beach, CA</span><span class="dot">·</span><span class="loc">Orange County &amp; Southern California</span>
      <br><span class="legal">501(c)(3) nonprofit · EIN 99-1232582</span>
    </div>
  </main>

  <script>
    var form = document.getElementById('notify-form');
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var data = new FormData(form);
      fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(data).toString()
      }).then(function () {
        form.hidden = true;
        document.getElementById('notify-success').hidden = false;
      }).catch(function () {
        form.submit();
      });
    });
  </script>
</body>
</html>
