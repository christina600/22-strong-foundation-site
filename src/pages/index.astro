---
/**
 * Homepage — the entire site, as one continuous scroll.
 *
 * [data-reveal] elements are animated in on scroll by home-reveal.ts;
 * styling lives in src/styles/home.css (loaded only via HomeBase).
 */

import HomeBase from "../layouts/HomeBase.astro";
import DonationModule from "../components/sections/DonationModule.astro";
---

<HomeBase title="Fund recovery care when the system stops short.">
  <div class="site">
    <header>
      <nav class="nav" aria-label="Main navigation">
        <a class="brand" href="#top">22 Strong Foundation</a>
        <div class="nav-links" aria-label="Section navigation">
          <a href="#how-it-works">How it works</a>
          <a href="#serve">Who we serve</a>
          <a href="#strong-circle">Strong Circle</a>
        </div>
        <div class="nav-actions">
          <a class="pill primary" href="#donate">Donate</a>
          <a class="pill" href="#contact">Contact</a>
        </div>
      </nav>
    </header>

    <main id="main">
      <!-- 1. HERO -->
      <section class="hero" id="top">
        <div class="hero-inner">
          <div class="hero-copy" data-reveal>
            <div class="eyebrow">22 Strong Foundation</div>
            <h1>Fund recovery care when the system stops short.</h1>
            <p class="lead">22 Strong Foundation helps donors turn generosity into hands-on recovery care for veterans, student athletes, cancer survivors, and neighbors whose next appointment is threatened by cost, timing, or access.</p>
            <p class="hero-tagline">Veteran-led. Care-funded. Orange County.</p>
            <a class="pill primary" href="#donate">Fund recovery care</a>
          </div>

          <div data-reveal>
            <DonationModule />
          </div>
        </div>
      </section>

      <section class="impact-snapshot" aria-label="22 Strong impact snapshot">
        <div class="impact-snapshot-inner" data-reveal>
          <div class="impact-snapshot-item">
            <strong>150+</strong>
            <span>recovery sessions funded since 2024</span>
          </div>
          <div class="impact-snapshot-item">
            <strong>18</strong>
            <span>people supported across Orange County</span>
          </div>
          <div class="impact-snapshot-item">
            <strong>$22K</strong>
            <span>current goal for the next wave of care</span>
          </div>
          <div class="impact-snapshot-item">
            <strong>Veteran-led</strong>
            <span>built by people who understand recovery</span>
          </div>
        </div>
      </section>

      <!-- 2. HOW 22 STRONG WORKS -->
      <section class="how-it-works" id="how-it-works">
        <div class="eyebrow" data-reveal>How 22 Strong works</div>
        <h2 data-reveal>A recovery gap appears.<br />22 Strong helps close it.</h2>

        <div class="steps">
          <div class="step" data-reveal>
            <span class="step-number">1</span>
            <h3>A need is identified</h3>
            <p>A person seeking care, provider, VA contact, coach, or community partner flags a recovery plan at risk of stopping too soon.</p>
          </div>
          <div class="step" data-reveal>
            <span class="step-number">2</span>
            <h3>We verify the gap</h3>
            <p>22 Strong reviews what is needed, what is available, and where cost, coverage, or connections are blocking the next appointment.</p>
          </div>
          <div class="step" data-reveal>
            <span class="step-number">3</span>
            <h3>Donor funds become care</h3>
            <p>Gifts cover recovery sessions directly &mdash; chiropractic, physical therapy, hands-on soft-tissue care, and integrative support at no cost to the person receiving care.</p>
          </div>
        </div>

        <div class="funding-covers" data-reveal>
          <div>
            <span class="eyebrow">What gifts cover</span>
            <h3>Appointments, not abstractions.</h3>
            <p>Funding supports practical recovery care for people with a clear need and a real access gap.</p>
          </div>

          <ul>
            <li>
              <strong>Hands-on recovery sessions</strong>
              <span>Chiropractic, physical therapy, soft-tissue care, and integrative support.</span>
            </li>
            <li>
              <strong>Follow-through after the first visit</strong>
              <span>Help staying with care long enough for recovery to keep moving.</span>
            </li>
            <li>
              <strong>Provider and partner referrals</strong>
              <span>A path for veterans, families, survivors, and neighbors who are already trying to get well.</span>
            </li>
          </ul>
        </div>

        <p class="how-note" data-reveal>Care is currently provided through Next Level Wellness Center in Newport Beach &mdash; a private facility with chiropractic, physical therapy, hands-on soft-tissue and myofascial therapy, rehabilitation, and recovery tools like muscle stimulation and compression therapy. As donor support grows, 22 Strong can expand toward a network of vetted providers across Southern California.</p>
      </section>

      <!-- 3. STRONG CIRCLE -->
      <section class="strong-circle-section" id="strong-circle">
        <div class="strong-circle-wrap">
          <div class="circle-panel" data-reveal>
            <div>
              <h2>Monthly support that keeps care moving.</h2>
              <p class="lead">The Strong Circle is the monthly giving community that helps 22 Strong plan care before a recovery gap turns into a stopped plan.</p>
            </div>

            <div>
              <div class="circle-number">$22</div>
              <h3 class="circle-subhead">A steady $22 helps us say yes faster</h3>
              <p class="circle-copy-tight">One-time gifts open the door. Monthly gifts create the reliable base behind the next appointment.</p>

              <div class="circle-actions">
                <button class="pill primary strong-circle-trigger" type="button" data-strong-circle-open>Join the Strong Circle</button>
                <a class="pill" href="#donate">Give once</a>
              </div>
            </div>
          </div>

          <div class="card" data-reveal>
            <h2 class="circle-card-title">Build the monthly base behind future recovery plans.</h2>
            <p>Recurring gifts help 22 Strong plan ahead for people referred by providers, coaches, veterans, and community partners.</p>

            <div class="circle-math">
              <div class="circle-math-row">
                <span>Monthly giving</span>
                <strong>$22/mo</strong>
              </div>
              <div class="circle-math-row">
                <span>Current goal</span>
                <strong>$22,000</strong>
              </div>
            </div>

            <div class="mini-list">
              <div class="mini-item">
                <h3>Make care predictable</h3>
                <p>A monthly gift gives the foundation a steadier way to fund care beyond the first appointment.</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <dialog class="strong-circle-modal" aria-labelledby="strong-circle-modal-title" aria-describedby="strong-circle-modal-description">
        <div class="strong-circle-modal-card">
          <button class="modal-close" type="button" data-strong-circle-close aria-label="Close Strong Circle popup">&times;</button>
          <span class="eyebrow">Monthly giving circle</span>
          <h2 id="strong-circle-modal-title">Join the Strong Circle.</h2>

          <div class="modal-commitment">
            <div class="modal-amount" aria-label="$22 per month">
              <span class="modal-amount-value">$22</span>
              <span class="modal-amount-period">/month</span>
            </div>

            <p class="lead" id="strong-circle-modal-description">A steady monthly gift gives 22 Strong a reliable base for appointments, follow-through, and urgent care gaps before someone has to ask twice.</p>
          </div>

          <div class="modal-proof-grid" aria-label="Strong Circle benefits">
            <div>
              <span>Steady support</span>
              <strong>Funds care beyond intake and the first visit.</strong>
            </div>
            <div>
              <span>Simple commitment</span>
              <strong>$264 across the year.</strong>
            </div>
          </div>

          <div class="modal-actions">
            <a class="pill primary" href="#donate" data-strong-circle-join>Start $22/month &rarr;</a>
            <a class="pill" href="#donate" data-strong-circle-close>Give once instead</a>
          </div>
        </div>
      </dialog>

      <!-- 4. WHO WE SERVE — split by group, each with its own proof.
           Stat bands and testimonials live with the group they describe.
           Add new stats/testimonials inside the matching group below. -->
      <section id="serve">
        <div class="serve-intro">
          <h2 data-reveal>Specialized recovery care for people whose next appointment is at risk.</h2>
          <p class="lead" data-reveal>22 Strong focuses on people with a real recovery need and a practical access gap: cost, coverage, timing, or the right connection to care.</p>
        </div>
      </section>

      <!-- 4a. VETERANS -->
      <section class="serve-group" id="serve-veterans">
        <div class="serve-group-head" data-reveal>
          <h2>Veterans</h2>
        </div>
      </section>

      <section class="serve-detail" aria-label="Veteran recovery support">
        <div class="serve-detail-inner">
          <div class="serve-copy" data-reveal>
            <p class="lead">Care funding for veterans rebuilding strength, mobility, and function after service.</p>
            <p>Support that respects the long work of recovery and helps keep care moving when benefits, timing, or access are not enough.</p>
          </div>

          <div class="serve-stats">
            <aside class="proof-stat" data-reveal>
              <div class="proof-stat-inner">
                <div class="proof-stat-number">1 in 3</div>
                <div class="proof-stat-text">
                  <p>veterans report chronic pain after service. When pain is part of daily life, recovery care should not be treated as optional.</p>
                  <span class="proof-stat-source"><a href="https://www.cdc.gov/mmwr/volumes/69/wr/mm6947a6.htm" target="_blank" rel="noopener">CDC &mdash; National Health Interview Survey</a></span>
                </div>
              </div>
            </aside>

            <aside class="proof-stat light" data-reveal>
              <div class="proof-stat-inner">
                <div class="proof-stat-number">38%</div>
                <div class="proof-stat-text">
                  <p>of post-9/11 veterans have not used VA health care since leaving the service.</p>
                  <span class="proof-stat-source"><a href="https://www.publichealth.va.gov/epidemiology/reports/oefoifond/health-care-utilization/" target="_blank" rel="noopener">VA Office of Public Health</a></span>
                </div>
              </div>
            </aside>
          </div>
        </div>
      </section>

      <section class="serve-proof">
        <div class="testimonial-grid">
          <article class="testimonial-card" data-reveal>
            <div>
              <div class="testimonial-video-shell" data-lazy-video>
                <button
                  class="testimonial-video-trigger"
                  type="button"
                  data-lazy-video-trigger
                  data-video-src="/video/luke-hudson-testimonial.mp4"
                  data-video-poster="/images/luke-poster.jpg"
                  aria-label="Play Luke Hudson testimonial video"
                >
                  <img
                    class="testimonial-video-poster"
                    src="/images/luke-poster.jpg"
                    alt=""
                    width="540"
                    height="960"
                    loading="lazy"
                    decoding="async"
                    fetchpriority="low"
                  />
                  <span class="testimonial-play-button" aria-hidden="true"></span>
                </button>
                <noscript>
                  <video class="testimonial-video" controls preload="none" playsinline poster="/images/luke-poster.jpg">
                    <source src="/video/luke-hudson-testimonial.mp4" type="video/mp4" />
                    <a href="/video/luke-hudson-testimonial.mp4">Watch Luke&rsquo;s testimonial</a>.
                  </video>
                </noscript>
              </div>
              <div class="attribution">Luke Hudson &middot; Veteran, VA referral</div>
              <p class="story">Luke shares why access to hands-on recovery care matters after service.</p>
            </div>
          </article>
        </div>
      </section>

      <!-- 4b. STUDENT ATHLETES -->
      <section class="serve-group" id="serve-athletes">
        <div class="serve-group-head" data-reveal>
          <h2>Student athletes</h2>
        </div>
      </section>

      <section class="serve-detail" aria-label="Student athlete recovery support">
        <div class="serve-detail-inner">
          <div class="serve-copy" data-reveal>
            <p class="lead">Recovery support for young athletes whose care requires more than a basic return-to-play plan.</p>
            <p>Support for families facing a season-ending injury, limited coverage, or care that stops before the athlete is ready.</p>
          </div>

          <div class="serve-stats one-up">
            <aside class="proof-stat" data-reveal>
              <div class="proof-stat-inner">
                <div class="proof-stat-number">21%</div>
                <div class="proof-stat-text">
                  <p>of high school sports injuries can end a season. The right recovery support can protect more than a roster spot.</p>
                  <span class="proof-stat-source"><a href="https://pmc.ncbi.nlm.nih.gov/articles/PMC2267335/" target="_blank" rel="noopener">Journal of Athletic Training</a></span>
                </div>
              </div>
            </aside>
          </div>
        </div>
      </section>

      <section class="serve-proof">
        <div class="quote-wrap">
          <img class="quote-photo" src="/images/adam-folker-uci.webp" alt="Adam Folker" width="1200" height="800" loading="lazy" decoding="async" fetchpriority="low" data-reveal />

          <div data-reveal>
            <blockquote>&ldquo;A major part of my success was the treatments and therapy I received from Dr. Vas.&rdquo;</blockquote>
            <div class="attribution">Adam Folker &middot; Collegiate &amp; Professional Basketball Player</div>
            <p class="story">During my sophomore year in college, I had hip surgery that was potentially season-ending and even career-ending. My coaches referred me to Dr. Vas, who was able to take care of me and eventually get me back to playing within a short few weeks. That season I ended up winning hustle player of the year award. Throughout my career, I saw Dr. Vas on various occasions for injuries that came up, along with maintenance and preventive care. I was able to play competitively at the top level.</p>
          </div>
        </div>
      </section>

      <!-- 4c. CANCER SURVIVORS -->
      <section class="serve-group" id="serve-cancer">
        <div class="serve-group-head" data-reveal>
          <h2>Cancer survivors</h2>
        </div>
      </section>

      <section class="serve-detail" aria-label="Cancer survivor recovery support">
        <div class="serve-detail-inner">
          <div class="serve-copy" data-reveal>
            <p class="lead">Support for survivors rebuilding strength and mobility after treatment.</p>
            <p class="support-note">22 Strong is expanding this pathway for survivors in the recovery phase: after treatment has ended, when rebuilding strength, movement, and confidence becomes the next hard work.</p>
          </div>

          <div class="serve-stats one-up">
            <aside class="proof-stat light" data-reveal>
              <div class="proof-stat-inner">
                <div class="proof-stat-number">nearly 19M</div>
                <div class="proof-stat-text">
                  <p>Americans are living as cancer survivors. For many, treatment ending is only the start of rebuilding strength.</p>
                  <span class="proof-stat-source"><a href="https://www.cancer.org/research/cancer-facts-statistics/survivor-facts-figures.html" target="_blank" rel="noopener">American Cancer Society</a></span>
                </div>
              </div>
            </aside>
          </div>
        </div>
      </section>

      <!-- 4d. OTHERS WHO NEED CARE (carries the general cost-of-care stats) -->
      <section class="serve-group" id="serve-others">
        <div class="serve-group-head" data-reveal>
          <h2>Others who need care</h2>
        </div>
      </section>

      <section class="serve-detail" aria-label="Recovery support for others who need care">
        <div class="serve-detail-inner">
          <div class="serve-copy" data-reveal>
            <p class="lead">A funding path for people referred by trusted providers and partners when recovery is stalled by access or cost.</p>
            <p>This pathway is for neighbors whose care plan is clear, but the next appointment depends on coverage, connection, or the ability to pay privately.</p>
          </div>

          <div class="serve-stats">
            <aside class="proof-stat" data-reveal>
              <div class="proof-stat-inner">
                <div class="proof-stat-number">$190</div>
                <div class="proof-stat-text">
                  <p>is the typical cost of one outpatient physical-therapy session for someone paying without insurance.</p>
                  <span class="proof-stat-source"><a href="https://www.cbsnews.com/news/physical-therapy-insurance-coverage-session-limits/" target="_blank" rel="noopener">CBS News / KFF Health News</a></span>
                </div>
              </div>
            </aside>

            <aside class="proof-stat light" data-reveal>
              <div class="proof-stat-inner">
                <div class="proof-stat-number">20 visits</div>
                <div class="proof-stat-text">
                  <p>a year is a common insurance cap on physical therapy &mdash; often less than recovery actually takes.</p>
                  <span class="proof-stat-source"><a href="https://www.cbsnews.com/news/physical-therapy-insurance-coverage-session-limits/" target="_blank" rel="noopener">CBS News / KFF Health News</a></span>
                </div>
              </div>
            </aside>
          </div>
        </div>
      </section>

      <!-- 5. LEADERSHIP -->
      <section id="leadership">
        <h2 data-reveal>Built by people who understand recovery.</h2>

        <div class="bios">
          <article class="card" data-reveal>
            <div class="bio-head">
              <img class="portrait" src="/images/dr-vas.webp" alt="Dr. Vasili &ldquo;Dr. Vas&rdquo; Gatsinaris" width="400" height="560" loading="lazy" decoding="async" fetchpriority="low" />
              <div>
                <h3>Dr. Vasili &ldquo;Dr. Vas&rdquo; Gatsinaris, D.C.</h3>
                <p class="bio-role">Founder</p>
              </div>
            </div>
            <p>Dr. Vas earned his Doctorate of Chiropractic from the Los Angeles College of Chiropractic in 2001 and has more than 25 years of experience helping people recover and rebuild.</p>
            <p>Over his career, he has worked with everyone from professional athletes to first responders, developing a hands-on, integrative approach focused on restoring mobility and getting people back to life stronger and faster.</p>
            <p>He is co-owner of Next Level Fitness &amp; Wellness Center in Irvine, a full-service wellness facility offering chiropractic, physical and massage therapy, and nutrition &mdash; the same integrative recovery care 22 Strong helps fund.</p>
          </article>

          <article class="card" data-reveal>
            <div class="bio-head">
              <div class="initials">TM</div>
              <div>
                <h3>Travis Mayfield</h3>
                <p class="bio-role">Co-founder</p>
              </div>
            </div>
            <p>A Purple Heart Army veteran who served with the 101st Airborne, Travis is Co-Owner and President of Next Level Fitness &amp; Wellness Center. He helped bring 22 Strong together and leads its mission to make recovery care accessible to those who served and to others working to rebuild.</p>
            <p>His own path from service informs how 22 Strong shows up for the people it serves: with respect, follow-through, and care that doesn&rsquo;t stop at the first appointment.</p>
          </article>
        </div>
      </section>

      <!-- 6. AS FEATURED IN -->
      <section class="featured" id="featured" aria-label="Press feature">
        <div class="featured-inner" data-reveal>
          <p class="featured-kicker"><span>As featured in</span></p>

          <figure class="featured-sheet">
            <img
              class="featured-logo-img"
              src="/images/logo-usvm.jpg"
              alt="U.S. Veterans Magazine"
              width="760"
              height="194"
              loading="lazy"
              decoding="async"
              fetchpriority="low"
            />
            <figcaption class="featured-issue">Winter 2022 Issue</figcaption>
          </figure>

          <p class="featured-line">The wellness partnership behind 22&nbsp;Strong.</p>
          <a class="featured-link" href="https://digital.usveteransmagazine.com/US-Veterans-Magazine-Winter-2022/0/" target="_blank" rel="noopener">Read the feature &rarr;</a>
        </div>
      </section>

      <!-- 7. DONATE -->
      <section class="donate-section" id="donate">
        <div class="donate-wrap">
          <div>
            <h2 data-reveal>Fund the next $22,000 in recovery care.</h2>
            <p class="lead" data-reveal>Every gift helps turn a stalled recovery plan into appointments someone can actually reach.</p>
            <p class="outcomes" data-reveal>Since 2024, donor support has funded over 150 recovery sessions for 18 people across Orange County.</p>

            <div class="goal-panel" aria-label="Fundraising goal preview" data-reveal>
              <div class="goal-top">
                <span>Current goal</span>
                <span>$22,000</span>
              </div>
              {/* Decorative bar: the 22% fill is a brand motif, not real
                  fundraising progress, so it's hidden from assistive tech to
                  avoid announcing a fabricated "% of goal" value. */}
              <div class="goal-bar" aria-hidden="true">
                <div class="goal-fill"></div>
              </div>
              <p class="goal-copy">$22,000 covers roughly 115 recovery sessions &mdash; enough to help 10&ndash;15 people stay with a complete care plan.</p>
            </div>
          </div>

          <div data-reveal>
            <DonationModule />
          </div>
        </div>
      </section>

      <!-- 8. CONTACT -->
      <section class="contact" id="contact">
        <div class="split">
          <div data-reveal>
            <h2>Start the right conversation with 22 Strong.</h2>
            <p>Use this form to give, refer someone, explore a partnership, or ask about care. Please do not use it for emergencies or private medical details.</p>

            <ul class="contact-paths" aria-label="Ways to contact 22 Strong">
              <li>
                <strong>Give or sponsor care</strong>
                <span>Help fund sessions for someone whose plan is at risk.</span>
              </li>
              <li>
                <strong>Refer someone</strong>
                <span>Start a conversation for a veteran, athlete, survivor, or neighbor.</span>
              </li>
              <li>
                <strong>Partner with us</strong>
                <span>Connect providers, community groups, and recovery resources.</span>
              </li>
            </ul>
          </div>

          <form id="contactFormEl" aria-describedby="contact-form-note contact-form-status" data-reveal>
            <div class="hp" aria-hidden="true">
              <label>Website
                <input type="text" name="website" tabindex="-1" autocomplete="off" />
              </label>
            </div>

            <div class="form-row">
              <label>Name
                <input type="text" name="name" required />
              </label>
              <label>Email
                <input type="email" name="email" required />
              </label>
            </div>

            <label>Reason for contact
              <select name="reason">
                <option>I want to give or sponsor care</option>
                <option>I want to refer someone for care</option>
                <option>I want to partner with 22 Strong</option>
                <option>I have a general question</option>
              </select>
            </label>

            <label>Message
              <textarea name="message" required></textarea>
            </label>

            <p class="note" id="contact-form-note">Please do not include private medical details, urgent needs, or anything you would not want sent through a basic web form.</p>
            <p class="form-status" id="contact-form-status" role="status" aria-live="polite" hidden></p>
            <button class="pill primary form-submit" type="submit">Send message</button>
          </form>
        </div>
      </section>
    </main>

    <!-- 9. FOOTER -->
    <footer>
      <div class="footer-inner">
        <div>
          <div class="footer-title">22 Strong Foundation</div>
          <p>&copy; 2026 22 Strong Foundation &middot; 501(c)(3) &middot; <span class="nowrap">EIN 99-1232582</span></p>
        </div>

        <div>
          <div class="footer-title">Explore</div>
          <div class="links">
            <a href="#how-it-works">How it works</a>
            <a href="#strong-circle">Strong Circle</a>
            <a href="#serve">Who we serve</a>
            <a href="#serve-veterans">Veterans</a>
          </div>
        </div>

        <div>
          <div class="footer-title">Get involved</div>
          <div class="links">
            <a href="#donate">Donate</a>
            <a href="#contact">Get in touch</a>
          </div>
        </div>
      </div>
    </footer>
  </div>

  <script>
    import "../scripts/strong-circle-modal.ts";
    import "../scripts/lazy-video.ts";
  </script>
</HomeBase>
