---
/**
 * Homepage — the site as one continuous recovery story.
 *
 * Each component below has a single editorial job:
 * conflict, proof, origin, audience stakes, care path, donor action.
 */

import HomeBase from "../layouts/HomeBase.astro";
import AudienceSection from "../components/sections/AudienceSection.astro";
import BlankSection from "../components/sections/BlankSection.astro";
import ContactSection from "../components/sections/ContactSection.astro";
import DonationAskSection from "../components/sections/DonationAskSection.astro";
import GivingInvite from "../components/sections/GivingInvite.astro";
import HeroSection from "../components/sections/HeroSection.astro";
import ImpactSection from "../components/sections/ImpactSection.astro";
import NarrativeScene from "../components/sections/NarrativeScene.astro";
import ServicePathSection from "../components/sections/ServicePathSection.astro";
import SectionCta from "../components/sections/SectionCta.astro";
import StrongCircleSection from "../components/sections/StrongCircleSection.astro";
import SiteHeader from "../components/sections/SiteHeader.astro";
import SiteFooter from "../components/sections/SiteFooter.astro";
import VeteranStorySection from "../components/sections/VeteranStorySection.astro";
import home from "../content/home.json";
import { buildAudienceGroups } from "../utils/home-story";

const audienceGroups = buildAudienceGroups(home);
const [costStat, , debtStat] = home.stats.others;
---

<HomeBase title="Fund recovery care when the system stops short.">
  <div class="site">
    <SiteHeader current="home" />

    <main id="main">
      <HeroSection proofline={home.credibility} />
      <BlankSection class="post-hero-section" id="post-hero-blank" padding="default" ariaHidden={false}>
        <div class="post-hero-message">
          {home.hero.kicker && <p class="hero-kicker">{home.hero.kicker}</p>}
          <h1 class="hero-headline">
            {home.hero.headline.map((line) => <span class="hero-headline-line">{line}</span>)}
          </h1>
        </div>
      </BlankSection>
      <BlankSection padding="none" id="hero-lead" ariaHidden={false}>
        <div class="hero-lead">
          <p class="hero-lead-statement" data-reveal="headline">{home.heroLead}</p>
        </div>
      </BlankSection>

      <section class="stat-bridge" data-parallax aria-label="Recovery gap statistic">
        <div class="stat-bridge__media" data-parallax-media style="--bg-image: url(/images/story-assisted-rehab.webp)"></div>
        <div class="stat-bridge__content">
          <p class="stat-bridge__number">20 visits</p>
          <p class="stat-bridge__body">a year is a common insurance cap on physical therapy — often less than recovery actually takes.</p>
          <p class="stat-bridge__source">CBS News</p>
          <a class="pill primary stat-bridge__cta" href="#donate">{home.hero.ctaLabel}</a>
        </div>
      </section>

      <AudienceSection chapter="01" introTitle="Who we serve" groups={audienceGroups} />

      <NarrativeScene
        chapter="02"
        id="about"
        heading={home.mission.heading}
        lead={home.mission.lead}
        evidenceStats={[costStat, debtStat]}
        evidenceAriaLabel="Evidence of the recovery access gap"
        needParagraphs={home.mission.needParagraphs}
        paragraphs={home.story.paragraphs}
        media={{
          src: "/images/story-treatment-room.webp",
          alt: "Hands providing shoulder mobility treatment during a rehab session",
          caption: "The gap shows up where recovery actually happens: in the treatment room.",
          imagePosition: "50% 50%"
        }}
      />

      <ImpactSection
        heading="Every number represents care that did not stop when coverage did."
        impact={home.mission.impact}
      />

      <ServicePathSection chapter="03" content={home.howItWorks} />

      <VeteranStorySection />

      <StrongCircleSection strongCircle={home.strongCircle} />

      <SectionCta text="Care shouldn't stop because the next visit isn't covered." label="Fund recovery care" href="#donate" />

      <DonationAskSection chapter="04" donate={home.donate} />
      <ContactSection contact={home.contact} />
    </main>

    <SiteFooter footer={home.footer} />
    <GivingInvite />
  </div>
</HomeBase>
