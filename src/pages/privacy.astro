---
/**
 * Privacy Policy page.
 */

import Page from "../layouts/Page.astro";
import PolicyPlaceholder from "../components/sections/PolicyPlaceholder.astro";
import ContactPreview from "../components/sections/ContactPreview.astro";

import pageData from "../content/pages/privacy.json";
---

<Page
  title={pageData.label}
  eyebrow={pageData.eyebrow}
  headline={pageData.title}
  intro={pageData.intro}
  currentPage="privacy"
  description={pageData.metaDescription}
  ogImage={pageData.ogImage}
>
  <PolicyPlaceholder policyLabel="Privacy Policy" />
  <ContactPreview />
</Page>
