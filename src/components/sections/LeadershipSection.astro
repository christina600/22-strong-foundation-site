---
import { Image } from "astro:assets";
import { getImageByPath } from "../../assets/images";

interface Leader {
  name: string;
  role: string;
  portrait?: string;
  portraitAlt?: string;
  portraitPosition?: string;
  initials?: string;
  credentials?: string[];
  paragraphs: string[];
}

interface Props {
  people: Leader[];
  headingLevel?: "h1" | "h2";
}

const { people, headingLevel = "h2" } = Astro.props;
const HeadingTag = headingLevel;
---

<section class="story-leadership" id="leadership">
  <HeadingTag data-reveal="headline">Meet the team.</HeadingTag>

  <div class="bios">
    {people.map((person, index) => (
      <article class="card" data-reveal="card" data-delay={(index + 1).toString()}>
        <div class="bio-head">
          {person.portrait
            ? (() => {
                const asset = getImageByPath(person.portrait);
                const style = person.portraitPosition
                  ? `--portrait-position: ${person.portraitPosition};`
                  : undefined;
                return asset
                  ? <Image class="portrait" style={style} data-reveal="image" src={asset} alt={person.portraitAlt ?? person.name} width={400} height={560} loading="lazy" decoding="async" fetchpriority="low" sizes="(max-width: 560px) 118px, (max-width: 920px) 148px, 176px" widths={[160, 240, 320, 480]} quality={86} />
                  : <img class="portrait" style={style} data-reveal="image" src={person.portrait} alt={person.portraitAlt ?? person.name} width="400" height="560" loading="lazy" decoding="async" fetchpriority="low" />;
              })()
            : <div class="initials">{person.initials}</div>}
          <div>
            <h3>{person.name}</h3>
            <p class="bio-role">{person.role}</p>
            {person.credentials && (
              <ul class="bio-credentials" aria-label={`${person.name} credentials`}>
                {person.credentials.map((credential) => <li>{credential}</li>)}
              </ul>
            )}
          </div>
        </div>
        {person.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
      </article>
    ))}
  </div>
</section>
