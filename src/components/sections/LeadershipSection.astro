---
import { Image } from "astro:assets";
import { getImageByPath } from "../../assets/images";

interface Leader {
  name: string;
  role: string;
  portrait?: string;
  portraitAlt?: string;
  initials?: string;
  paragraphs: string[];
}

interface Props {
  people: Leader[];
  headingLevel?: "h1" | "h2";
}

const { people, headingLevel = "h2" } = Astro.props;
const HeadingTag = headingLevel;
---

<section class="story-leadership" id="leadership">
  <HeadingTag data-reveal="headline">Meet the team.</HeadingTag>

  <div class="bios">
    {people.map((person, index) => (
      <article class="card" data-reveal="card" data-delay={(index + 1).toString()}>
        <div class="bio-head">
          {person.portrait
            ? (() => {
                const asset = getImageByPath(person.portrait);
                return asset
                  ? <Image class="portrait" data-reveal="image" src={asset} alt={person.portraitAlt ?? person.name} width={400} height={560} loading="lazy" decoding="async" fetchpriority="low" sizes="(max-width: 560px) 30vw, (max-width: 920px) 25vw, 120px" widths={[120, 240, 400]} />
                  : <img class="portrait" data-reveal="image" src={person.portrait} alt={person.portraitAlt ?? person.name} width="400" height="560" loading="lazy" decoding="async" fetchpriority="low" />;
              })()
            : <div class="initials">{person.initials}</div>}
          <div>
            <h3>{person.name}</h3>
            <p class="bio-role">{person.role}</p>
          </div>
        </div>
        {person.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
      </article>
    ))}
  </div>
</section>
