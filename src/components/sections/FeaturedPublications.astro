---
import { Image } from "astro:assets";
import { getImageByPath } from "../../assets/images";

interface Publication {
  name: string;
  logo: string;
  logoAlt: string;
  url: string;
  ariaLabel: string;
  featureLine?: string;
  sourceLabel?: string;
}

interface Props {
  chapter?: string;
  heading?: string;
  publications: Publication[];
}

const { chapter, heading = "As Featured In", publications } = Astro.props;
const singleFeature = publications.length === 1 ? publications[0] : undefined;
---

<section class="featured story-press" id="featured" aria-labelledby="featured-title" data-chapter={chapter}>
  <div class="featured-inner" data-reveal>
    <h2 class="featured-title" id="featured-title" data-reveal="headline">{heading}</h2>
    {singleFeature?.featureLine ? (
      <a
        class="featured-quote"
        href={singleFeature.url}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={singleFeature.ariaLabel}
        data-reveal="card"
      >
        <span class="featured-quote__eyebrow">Featured coverage</span>
        <p>{singleFeature.featureLine}</p>
        <span class="featured-quote__source">{singleFeature.sourceLabel ?? singleFeature.name}</span>
      </a>
    ) : (
      <ul class="featured-publications" aria-label="Featured publications">
        {publications.map((publication) => {
        const asset = getImageByPath(publication.logo);
        return (
          <li data-reveal="card">
            <a
              class="featured-sheet"
              href={publication.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={publication.ariaLabel}
            >
              {asset
                ? <Image
                    class="featured-logo-img"
                    src={asset}
                    alt={publication.logoAlt}
                    width={760}
                    height={194}
                    loading="lazy"
                    decoding="async"
                    fetchpriority="low"
                    format="webp"
                  />
                : <img
                    class="featured-logo-img"
                    src={publication.logo}
                    alt={publication.logoAlt}
                    width="760"
                    height="194"
                    loading="lazy"
                    decoding="async"
                    fetchpriority="low"
                  />
              }
            </a>
          </li>
        );
        })}
      </ul>
    )}
  </div>
</section>
