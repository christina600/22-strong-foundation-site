---
interface Props {
  /** Optional custom CSS class for additional styling */
  class?: string;
  /** Optional id for anchor linking */
  id?: string;
  /** Hide purely decorative spacer sections from assistive tech */
  ariaHidden?: boolean;
  /** Optional padding override - defaults to medium spacing */
  padding?: "none" | "tight" | "default" | "roomy";
}

const { class: className = "", id, ariaHidden = true, padding = "default" } = Astro.props;

const paddingClasses = {
  none: "blank-section--none",
  tight: "blank-section--tight",
  default: "blank-section--default",
  roomy: "blank-section--roomy",
};

const sectionClass = ["blank-section", paddingClasses[padding], className]
  .filter(Boolean)
  .join(" ");
---

<section class={sectionClass} id={id} aria-hidden={ariaHidden ? "true" : undefined}>
  <div class="blank-section-inner">
    <slot />
  </div>
</section>

<style is:global>
  .blank-section {
    width: 100%;
  }

  .blank-section-inner {
    width: min(var(--max), 100%);
    max-width: var(--max);
    margin: 0 auto;
    padding-inline: var(--space-page-x);
  }

  .blank-section--none { padding-block: 0; }
  .blank-section--tight { padding-block: var(--space-section-y-tight); }
  .blank-section--default { padding-block: var(--space-section-y); }
  .blank-section--roomy { padding-block: var(--space-section-y-roomy); }

  @media (prefers-reduced-motion: reduce) {
    .blank-section * {
      animation: none !important;
      transition: none !important;
    }
  }
</style>
