---
/**
 * Programs List — shared photo-forward card grid used by ProgramPreview and ProgramGrid.
 * Reads programs from programs.json and site.json for the phone number.
 *
 * Each program renders as a full-bleed photo card: a parallax image layer
 * (gradient placeholder until a real `image` is supplied), a legibility scrim,
 * and overlaid editorial numeral + tag + title + text + "view program" link.
 * The first program is featured as a larger card spanning the grid.
 */

import { programList } from "../../lib/programs";
import site from "../../content/site.json";

const phoneDigits = site.phone.replace(/[^0-9]/g, "");

// A family of editorial line glyphs — one per card, assigned by index.
// All share the same 32x32 viewBox, stroke weight, and round caps so they
// read as one brand system. Each rotates + deepens to burnt-orange on hover.
const glyphAttrs = `viewBox="0 0 32 32" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"`;
const glyphs = [
  // Six-point asterisk
  `<svg ${glyphAttrs}><line x1="16" y1="4" x2="16" y2="28"/><line x1="5.6" y1="10" x2="26.4" y2="22"/><line x1="5.6" y1="22" x2="26.4" y2="10"/></svg>`,
  // Four-point sparkle
  `<svg ${glyphAttrs}><path d="M16 4 C17 12 20 15 28 16 C20 17 17 20 16 28 C15 20 12 17 4 16 C12 15 15 12 16 4 Z"/></svg>`,
  // Ring with center dot
  `<svg ${glyphAttrs}><circle cx="16" cy="16" r="11"/><circle cx="16" cy="16" r="1.7" fill="currentColor" stroke="none"/></svg>`,
  // Diamond
  `<svg ${glyphAttrs}><path d="M16 4 L28 16 L16 28 L4 16 Z"/></svg>`,
  // Upward triangle
  `<svg ${glyphAttrs}><path d="M16 5 L27 25 L5 25 Z"/></svg>`,
  // Plus
  `<svg ${glyphAttrs}><line x1="16" y1="5" x2="16" y2="27"/><line x1="5" y1="16" x2="27" y2="16"/></svg>`,
  // Eight-point asterisk
  `<svg ${glyphAttrs}><line x1="16" y1="4" x2="16" y2="28"/><line x1="4" y1="16" x2="28" y2="16"/><line x1="7.5" y1="7.5" x2="24.5" y2="24.5"/><line x1="7.5" y1="24.5" x2="24.5" y2="7.5"/></svg>`,
];
---

<div class="programs-intro scroll-dynamic">
  <p class="programs-reassure">Better in 90 runs in three phases over 90 days, with maintenance care beyond. Eligible participants take part at no cost.</p>
  <a class="btn programs-now" href={`tel:${phoneDigits}`}>Call {site.phone} &rarr;</a>
</div>

<div class="program-cards">
  {programList.map((item, i) => {
    // Virgo (a11y): only announce the photo to screen readers when a REAL
    // image exists. Gradient placeholders are decorative — exposing their
    // (template) alt text would read instruction prose aloud. So we set
    // role/aria-label only when item.image is filled, else hide it.
    const photoA11y = item.image
      ? { role: "img", "aria-label": item.imageAlt || "" }
      : { "aria-hidden": "true" };
    return (
    <a
      class={`program-card scroll-dynamic${i === 0 ? " is-featured" : ""}`}
      href={`/${item.page}`}
      aria-label={`${item.title} — view program`}
    >
      <span
        class="program-card-photo"
        transition:name={`pphoto-${item.page}`}
        style={`background-image: ${item.background}`}
        {...photoA11y}
      ></span>
      <span class="program-card-scrim" aria-hidden="true"></span>
      <span class="program-card-content">
        <span class="program-card-mark" aria-hidden="true" set:html={glyphs[i % glyphs.length]}></span>
        <span class="program-card-text">
          {item.tag && <span class="program-card-tag">{item.tag}</span>}
          <h3 transition:name={`ptitle-${item.page}`}>{item.title}</h3>
          <p>{item.text}</p>
          <span class="program-card-go">
            View program <span aria-hidden="true">&rarr;</span>
          </span>
        </span>
      </span>
    </a>
    );
  })}
</div>
