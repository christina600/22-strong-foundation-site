---
import { Image } from "astro:assets";
import type { AudienceGroupContent } from "../../utils/home-story";
import { getImageByPath } from "../../assets/images";
import TestimonialVideo from "./TestimonialVideo.astro";

interface Props {
  chapter?: string;
  introTitle: string;
  groups: AudienceGroupContent[];
}

const { chapter, introTitle, groups } = Astro.props;
// Evidence stats live on the How It Works page; cards stay introductory.
const preparedGroups = groups.map((group) => ({
  ...group,
  helpLine: group.body
}));
---

<section class="story-serve-intro audience-card-section" id="serve" data-chapter={chapter}>
  <div class="serve-intro">
    <h2 data-reveal="headline">{introTitle}</h2>
  </div>

  <div class="audience-card-grid" aria-label="Who 22STRONG serves">
    {preparedGroups.map((group) => (
      <article
        class={`audience-card${group.proofClass ? ` ${group.proofClass}` : ""}`}
        id={group.id}
        aria-label={group.detailAriaLabel}
        data-reveal="card"
      >
        {group.photo && (
          <div class="audience-card-photo">
            {(() => {
              const asset = getImageByPath(group.photo);
              return asset
                ? <Image
                    src={asset}
                    alt={group.photoAlt ?? group.heading}
                    width={900}
                    height={560}
                    loading="lazy"
                    decoding="async"
                    fetchpriority="low"
                    sizes="(max-width: 760px) 92vw, 44vw"
                    widths={[480, 720, 900, 1200]}
                    style={group.imagePosition ? `object-position: ${group.imagePosition};` : undefined}
                  />
                : <img
                    src={group.photo}
                    alt={group.photoAlt ?? group.heading}
                    width="900"
                    height="560"
                    loading="lazy"
                    decoding="async"
                    fetchpriority="low"
                    style={group.imagePosition ? `object-position: ${group.imagePosition};` : undefined}
                  />;
            })()}
          </div>
        )}
        <div class="audience-card__content">
          <div class="audience-card__intro">
            <span class="audience-card-name">{group.heading}</span>
            <p class="audience-card-sentence">{group.lead}</p>
          </div>

          {group.recoveryBeat && (
            <figure class="audience-recovery-beat">
              {(() => {
                const asset = getImageByPath(group.recoveryBeat.src);
                return asset
                  ? <Image
                      src={asset}
                      alt={group.recoveryBeat.alt}
                      width={1680}
                      height={720}
                      loading="lazy"
                      decoding="async"
                      fetchpriority="low"
                      sizes="(max-width: 760px) 92vw, 900px"
                      widths={[640, 900, 1200, 1680]}
                      style={group.recoveryBeat.imagePosition ? `object-position: ${group.recoveryBeat.imagePosition};` : undefined}
                    />
                  : <img
                      src={group.recoveryBeat.src}
                      alt={group.recoveryBeat.alt}
                      width="1680"
                      height="720"
                      loading="lazy"
                      decoding="async"
                      fetchpriority="low"
                      style={group.recoveryBeat.imagePosition ? `object-position: ${group.recoveryBeat.imagePosition};` : undefined}
                    />;
              })()}
            </figure>
          )}

          <div class="audience-card-help">
            <h3>How we help</h3>
            <p>{group.helpLine}</p>
          </div>

          {!group.videos?.length && group.voices.length > 0 && group.voices[0].photo && (
            <figure class="audience-voice audience-voice--person">
              <img
                class="audience-voice__photo audience-voice__photo--landscape"
                src={group.voices[0].photo}
                alt={group.voices[0].photoAlt ?? group.voices[0].name}
                width={group.voices[0].imageWidth ?? 1200}
                height={group.voices[0].imageHeight ?? 800}
                loading="lazy"
                decoding="async"
                fetchpriority="low"
                style={group.voices[0].imagePosition ? `object-position: ${group.voices[0].imagePosition};` : undefined}
              />
              {group.voices[0].quote && <blockquote class="audience-voice__quote">{group.voices[0].quote}</blockquote>}
              <figcaption class="audience-voice__cite">
                <cite class="audience-voice__cite-name">{group.voices[0].name}</cite>
                {group.voices[0].title && <span class="audience-voice__cite-role">{group.voices[0].title}</span>}
              </figcaption>
            </figure>
          )}
          {!group.voices.length && group.featurePhoto && (
            <figure class="audience-voice">
              {(() => {
                const asset = getImageByPath(group.featurePhoto.src);
                return asset
                  ? <Image
                      class="audience-voice__photo"
                      src={asset}
                      alt={group.featurePhoto.alt}
                      width={600}
                      height={1067}
                      loading="lazy"
                      decoding="async"
                      fetchpriority="low"
                      sizes="(max-width: 760px) 92vw, 300px"
                      widths={[300, 600, 900]}
                      style={group.featurePhoto.imagePosition ? `object-position: ${group.featurePhoto.imagePosition};` : undefined}
                    />
                  : <img
                      class="audience-voice__photo"
                      src={group.featurePhoto.src}
                      alt={group.featurePhoto.alt}
                      width="600"
                      height="1067"
                      loading="lazy"
                      decoding="async"
                      fetchpriority="low"
                      style={group.featurePhoto.imagePosition ? `object-position: ${group.featurePhoto.imagePosition};` : undefined}
                    />;
              })()}
            </figure>
          )}
          {group.videos && group.videos.length > 0 && (
            <TestimonialVideo
              class="audience-testimonial"
              src={group.videos[0].src}
              poster={group.videos[0].poster}
              playLabel={group.videos[0].triggerLabel}
              attribution={group.videos[0].attribution ?? ""}
              quote={group.videos[0].quote}
              story={group.videos[0].story}
              tone="light"
              layout="featured"
              motionBackdrop
            />
          )}
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .audience-voice {
    margin: 18px 0 0;
    display: grid;
    gap: 12px;
  }

  /* Matches the veterans card video footprint (Fix B) */
  .audience-voice__photo {
    display: block;
    width: 100%;
    max-width: 300px;
    height: auto;
    aspect-ratio: 9 / 16;
    border-radius: 12px;
    object-fit: cover;
  }

  .audience-voice__photo--landscape {
    max-width: none;
    aspect-ratio: 3 / 2;
  }

  .audience-voice__quote {
    margin: 0;
    font-size: clamp(1.3rem, 1.7vw, 1.5rem);
    font-weight: 600;
    line-height: 1.34;
  }

  .audience-voice__quote::before { content: "\201C"; }
  .audience-voice__quote::after { content: "\201D"; }

</style>
