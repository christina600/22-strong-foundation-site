---
import { Image } from "astro:assets";
import type { AudienceGroupContent } from "../../utils/home-story";
import { getImageByPath } from "../../assets/images";

interface Props {
  chapter?: string;
  introTitle: string;
  groups: AudienceGroupContent[];
}

const { chapter, introTitle, groups } = Astro.props;
const preparedGroups = groups.map((group) => ({
  ...group,
  primaryStat: group.stats[0],
  helpLine: group.body
}));
---

<section class="story-serve-intro audience-card-section" id="serve" data-chapter={chapter} data-bg-shift>
  <div class="serve-intro">
    <h2 data-reveal="headline" data-split-reveal>{introTitle}</h2>
  </div>

  <div class="audience-card-grid" aria-label="Who 22 Strong serves">
    {preparedGroups.map((group) => (
      <article
        class={`audience-card${group.proofClass ? ` ${group.proofClass}` : ""}`}
        id={group.id}
        aria-label={group.detailAriaLabel}
        data-reveal="card"
      >
        {group.photo && (
          <div class="audience-card-photo">
            {(() => {
              const asset = getImageByPath(group.photo);
              return asset
                ? <Image
                    src={asset}
                    alt={group.photoAlt ?? group.heading}
                    width={900}
                    height={560}
                    loading="lazy"
                    decoding="async"
                    fetchpriority="low"
                    sizes="(max-width: 760px) 92vw, 44vw"
                    widths={[480, 720, 900, 1200]}
                    style={group.imagePosition ? `object-position: ${group.imagePosition};` : undefined}
                  />
                : <img
                    src={group.photo}
                    alt={group.photoAlt ?? group.heading}
                    width="900"
                    height="560"
                    loading="lazy"
                    decoding="async"
                    fetchpriority="low"
                    style={group.imagePosition ? `object-position: ${group.imagePosition};` : undefined}
                  />;
            })()}
          </div>
        )}
        <span class="audience-card-name">{group.heading}</span>
        <p class="audience-card-sentence">{group.lead}</p>
        {group.primaryStat && (
          <div class="audience-card-stat">
            <strong>{group.primaryStat.number}</strong>
            <span>{group.primaryStat.text}</span>
            <a href={group.primaryStat.url} target="_blank" rel="noopener noreferrer">{group.primaryStat.source}</a>
          </div>
        )}
        {group.featuredVoice && (
          <figure class="audience-card-voice">
            {group.featuredVoice.videoSrc && group.featuredVoice.videoPoster && (
              <div class="audience-card-voice-media">
                {(() => {
                  const posterAsset = getImageByPath(group.featuredVoice.videoPoster);
                  return posterAsset
                    ? <Image
                        src={posterAsset}
                        alt={group.featuredVoice.photoAlt ?? group.featuredVoice.name}
                        width={540}
                        height={960}
                        loading="lazy"
                        decoding="async"
                        fetchpriority="low"
                        format="webp"
                      />
                    : <img
                        src={group.featuredVoice.videoPoster}
                        alt={group.featuredVoice.photoAlt ?? group.featuredVoice.name}
                        width="540"
                        height="960"
                        loading="lazy"
                        decoding="async"
                      />;
                })()}
                <video
                  class="audience-card-voice-video"
                  src={group.featuredVoice.videoSrc}
                  poster={group.featuredVoice.videoPoster}
                  preload="metadata"
                  playsinline
                  controls
                  aria-label={`${group.featuredVoice.name} testimonial video`}
                ></video>
              </div>
            )}
            <blockquote>
              <p>{group.featuredVoice.quote}</p>
            </blockquote>
            <figcaption>— {group.featuredVoice.name}, {group.featuredVoice.label}</figcaption>
          </figure>
        )}
        {group.videos && group.videos.length > 0 && group.videos.map((video, i) => (
          <figure class="audience-card-voice">
            <div class="audience-card-voice-media">
              {(() => {
                const posterAsset = getImageByPath(video.poster);
                return posterAsset
                  ? <Image
                      src={posterAsset}
                      alt={video.posterAlt ?? video.fallbackLabel}
                      width={540}
                      height={960}
                      loading="lazy"
                      decoding="async"
                      fetchpriority="low"
                      format="webp"
                    />
                  : <img
                      src={video.poster}
                      alt={video.posterAlt ?? video.fallbackLabel}
                      width="540"
                      height="960"
                      loading="lazy"
                      decoding="async"
                    />;
              })()}
              <video
                class="audience-card-voice-video"
                src={video.src}
                poster={video.poster}
                preload="metadata"
                playsinline
                controls
                aria-label={video.fallbackLabel}
              ></video>
            </div>
            {video.story && (
              <blockquote>
                <p>{video.story}</p>
              </blockquote>
            )}
            {video.attribution && <figcaption>— {video.attribution}</figcaption>}
          </figure>
        ))}
        <div class="audience-card-help">
          <h3>How we help</h3>
          <p>{group.helpLine}</p>
        </div>
      </article>
    ))}
  </div>
</section>
