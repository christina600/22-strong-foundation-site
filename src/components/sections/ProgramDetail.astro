---
/**
 * Program Detail — data-driven body for an individual program page.
 *
 * Reads the program from src/lib/programs.ts by slug, so every page
 * shows its own content (no more identical hardcoded markup).
 *
 * Layout: a main column (who it's for + what's included) beside a
 * sticky sidebar (how to start CTA + an honest "good to know" note).
 *
 * Props:
 *   slug — the program's page slug (matches programs.json `page`)
 */

import site from "../../content/site.json";
import copy from "../../content/program-detail.json";
import { getProgram } from "../../lib/programs";

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const program = getProgram(slug);
const phoneDigits = site.phone.replace(/[^0-9]/g, "");

const includes = program?.includes ?? [];
---

<section class="section program-detail">
  <div class="container">
    <!-- Belonging before eligibility (Cancer): reassure first, then describe fit. -->
    <div class="program-welcome scroll-dynamic">
      <p class="program-welcome-title">{copy.welcomeTitle}</p>
      <p class="program-welcome-body">{copy.welcomeBody}</p>
    </div>

    <div class="program-detail-grid">
      <div class="program-detail-main">
        <span class="eyebrow">Program access</span>
        <h2>Who this is for</h2>
        <p class="program-detail-lead">{program?.whoFor}</p>

        {program?.outcome && (
          <div class="program-feature scroll-dynamic">
            <p class="program-outcome">{program.outcome}</p>
            {program?.outcomeSource && (
              <p class="program-outcome-source">{program.outcomeSource}</p>
            )}
          </div>
        )}

        {includes.length > 0 && (
          <>
            <h3 class="program-includes-title">What this includes</h3>
            <ul class="program-includes scroll-dynamic">
              {includes.map((item) => <li>{item}</li>)}
            </ul>
          </>
        )}
      </div>

      <aside class="program-detail-aside">
        <div class="program-fact-card">
          <h3>How to start</h3>
          <p>{program?.howToStart}</p>
          <a class="btn" href={`tel:${phoneDigits}`}>Call {site.phone} &rarr;</a>
          <p class="program-start-alt">
            <span class="program-start-alt-label">{copy.startAltLabel}</span>
            {copy.startAltBody} <a href={`mailto:${site.email}`}>{site.email}</a>
          </p>
        </div>
        {program?.limits && (
          <div class="program-note">
            <h3>Good to know</h3>
            <p>{program.limits}</p>
          </div>
        )}
      </aside>
    </div>
  </div>
</section>
