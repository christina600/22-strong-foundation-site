---
/**
 * FAQ — accordion-style frequently asked questions.
 * Reads from faqs.json.
 */

import SectionShell from "../ui/SectionShell.astro";
import faqs from "../../content/faqs.json";
---

<SectionShell
  eyebrow="FAQ"
  title="Answers before people have to ask."
  body="These questions are here because reaching out can feel hard."
>
  <div class="faq">
    {faqs.map((item) => (
      <details>
        <summary>{item.q}</summary>
        <p>{item.a}</p>
      </details>
    ))}
  </div>
</SectionShell>
