---
import { Image } from "astro:assets";
import EvidenceStat, { type EvidenceStatContent } from "./EvidenceStat.astro";
import { getImageByPath } from "../../assets/images";

interface SceneMedia {
  src: string;
  alt: string;
  caption?: string;
  imagePosition?: string;
}

interface Props {
  chapter?: string;
  id: string;
  heading?: string;
  lead?: string;
  paragraphs?: string[];
  evidenceStats?: EvidenceStatContent[];
  evidenceAriaLabel?: string;
  needParagraphs?: string[];
  media?: SceneMedia;
}

const {
  chapter,
  id,
  heading,
  lead,
  paragraphs = [],
  evidenceStats = [],
  evidenceAriaLabel = "Supporting evidence",
  needParagraphs = [],
  media
} = Astro.props;
---

<section class={`about-section narrative-scene narrative-scene--${id}`} id={id} data-chapter={chapter} data-bg-shift>
  <div class="about-inner">
    <div class="about-intro" data-reveal>
      {heading && <h2 data-reveal="headline" data-split-reveal>{heading}</h2>}
      {lead && <p class="lead">{lead}</p>}
    </div>

    {evidenceStats.length > 0 && (
      <div class="about-evidence" role="list" aria-label={evidenceAriaLabel} data-reveal>
        {evidenceStats.map((stat) => <EvidenceStat stat={stat} variant="about" />)}
      </div>
    )}

    {needParagraphs.length > 0 && (
      <div class="about-need" data-reveal>
        {needParagraphs.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    )}

    {(media || paragraphs.length > 0) && (
      <div class="about-story-layout" data-reveal>
        {media && (
          <figure class="about-story-media">
            {(() => {
              const asset = getImageByPath(media.src);
              return asset
                ? <Image
                    src={asset}
                    alt={media.alt}
                    width={1200}
                    height={800}
                    loading="lazy"
                    decoding="async"
                    fetchpriority="low"
                    sizes="(max-width: 920px) 92vw, 42vw"
                    widths={[640, 900, 1200, 1600]}
                    style={media.imagePosition ? `object-position: ${media.imagePosition};` : undefined}
                  />
                : <img
                    src={media.src}
                    alt={media.alt}
                    width="1200"
                    height="800"
                    loading="lazy"
                    decoding="async"
                    fetchpriority="low"
                    style={media.imagePosition ? `object-position: ${media.imagePosition};` : undefined}
                  />;
            })()}
            {media.caption && <figcaption>{media.caption}</figcaption>}
          </figure>
        )}

        {paragraphs.length > 0 && (
          <div class="about-story">
            {paragraphs.map((paragraph) => <p>{paragraph}</p>)}
          </div>
        )}
      </div>
    )}
  </div>
</section>
