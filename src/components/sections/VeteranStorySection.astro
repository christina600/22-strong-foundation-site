---
// Cinematic chapter break: Veteran Care Testimonial video
// Full-width dark section; no carousel chrome, no ad wrapper.
import TestimonialVideo from "./TestimonialVideo.astro";
---

<section class="veteran-chapter" aria-label="Veterans in their own words">
  <div class="veteran-chapter-inner">
    <TestimonialVideo
      class="veteran-chapter-testimonial"
      src="/video/king-martin-testimonial.mp4"
      poster="/images/king-martin-poster.webp"
      playLabel="Play King Martin's veteran story"
      attribution="King Martin · Veteran"
      quote="He's giving his talents away for free to veterans, just to help them get their life together. When you have someone like that around, you get a chance to be a blessing on a whole other level."
      tone="dark"
      layout="featured"
      motionBackdrop
    />
  </div>
</section>
