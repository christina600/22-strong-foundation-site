---
import site from "../../content/site.json";
import { isConfigured } from "../../utils/config";

interface ContactPath {
  heading: string;
  body: string;
}

interface ContactContent {
  heading: string;
  body: string;
  pathsAriaLabel: string;
  paths: ContactPath[];
  honeypotLabel: string;
  nameLabel: string;
  emailLabel: string;
  reasonLabel: string;
  reasons: string[];
  messageLabel: string;
  note: string;
  submitLabel: string;
}

interface Props {
  contact: ContactContent;
}

const { contact } = Astro.props;
const contactEmail = isConfigured(site.email) ? site.email : undefined;
---

<section class="contact story-contact" id="contact">
  <div class="split">
    <div data-reveal>
      <h2>{contact.heading}</h2>
      {contact.body && <p>{contact.body}</p>}

      <ul class="contact-paths" aria-label={contact.pathsAriaLabel}>
        {contact.paths.map((path) => (
          <li>
            <span class="contact-path-check" aria-hidden="true"></span>
            <div class="contact-path-text">
              <strong>{path.heading}</strong>
              <span>{path.body}</span>
            </div>
          </li>
        ))}
      </ul>

      <figure class="contact-photo">
        <img
          src="/images/story-trx-training.webp"
          alt="Dr. Vas coaching a veteran through TRX suspension training at Next Level Wellness Center"
          loading="lazy"
        />
        <figcaption>The people on the other end of this form.</figcaption>
      </figure>
    </div>

    <form
      id="contactFormEl"
      action={contactEmail ? `mailto:${contactEmail}` : undefined}
      method={contactEmail ? "post" : undefined}
      enctype={contactEmail ? "text/plain" : undefined}
      aria-describedby="contact-form-note contact-form-status"
      data-contact-email={contactEmail}
      data-reveal
      novalidate
    >
      <div class="hp" aria-hidden="true">
        <label>{contact.honeypotLabel}
          <input type="text" name="website" tabindex="-1" autocomplete="off" />
        </label>
      </div>

      <div class="form-row">
        <div class="form-field">
          <label>{contact.nameLabel}
            <input type="text" name="name" autocomplete="name" required aria-describedby="name-error" />
          </label>
          <span class="field-error" id="name-error" role="alert" hidden></span>
        </div>
        <div class="form-field">
          <label>{contact.emailLabel}
            <input type="email" name="email" autocomplete="email" required aria-describedby="email-error" />
          </label>
          <span class="field-error" id="email-error" role="alert" hidden></span>
        </div>
      </div>

      <div class="form-field">
        <label>{contact.reasonLabel}
          <select name="reason" required aria-describedby="reason-error">
            <option value="">Select a reason...</option>
            {contact.reasons.map((reason) => <option>{reason}</option>)}
          </select>
        </label>
        <span class="field-error" id="reason-error" role="alert" hidden></span>
      </div>

      <div class="form-field">
        <label>{contact.messageLabel}
          <textarea name="message" required aria-describedby="message-error contact-form-note"></textarea>
        </label>
        <span class="field-error" id="message-error" role="alert" hidden></span>
      </div>

      <p class="note" id="contact-form-note">{contact.note}</p>
      <p class="form-status" id="contact-form-status" role="status" aria-live="polite" hidden></p>
      <button class="pill primary form-submit" type="submit">{contact.submitLabel}</button>
    </form>
  </div>
</section>
