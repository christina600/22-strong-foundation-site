---
import site from "../../content/site.json";
import { isConfigured } from "../../utils/config";

interface FooterSection {
  title: string;
  links: Array<{
    label: string;
    href: string;
  }>;
}

interface Props {
  footer: {
    sections: FooterSection[];
  };
  homeHrefPrefix?: string;
}

const { footer, homeHrefPrefix = "" } = Astro.props;
const hrefFor = (href: string) => href.startsWith("#") ? `${homeHrefPrefix}${href}` : href;
const orgMeta = [
  isConfigured(site.taxStatus) ? site.taxStatus : "",
  isConfigured(site.ein) ? `EIN ${site.ein}` : "",
].filter(isConfigured);
---

<footer>
  <div class="footer-inner">
    <div>
      <div class="footer-title">{site.orgName}</div>
      <p>&copy; 2026 {site.orgName}{orgMeta.length > 0 && <> &middot; {orgMeta.join(" · ")}</>}</p>
    </div>

    {footer.sections.map((section) => (
      <div>
        <div class="footer-title">{section.title}</div>
        <div class="links">
          {section.links.map((link) => <a href={hrefFor(link.href)}>{link.label}</a>)}
        </div>
      </div>
    ))}
  </div>
</footer>
