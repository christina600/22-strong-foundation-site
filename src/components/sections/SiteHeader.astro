---
interface Props {
  current?: "home" | "about" | "strong-circle" | "how-it-works" | "transparency" | "ways-to-support";
}

const { current = "home" } = Astro.props;
const isHome = current === "home";
const isAbout = current === "about";
const isStrongCircle = current === "strong-circle";
const isHowItWorks = current === "how-it-works";
const isWaysToSupport = current === "ways-to-support";
const homeHref = (hash: string) => isHome ? hash : `/${hash}`;
---

<header>
  <nav class="nav" aria-label="Main navigation">
    <a class="brand" href={isHome ? "#top" : "/"}>22 Strong Foundation</a>
    <button
      class="nav-toggle"
      aria-expanded="false"
      aria-controls="nav-menu"
      aria-label="Toggle navigation menu"
    >
      <span class="nav-toggle-icon" aria-hidden="true"></span>
    </button>
    <div class="nav-links" id="nav-menu" aria-label="Section navigation">
      <a
        href="/how-it-works/"
        class:list={{ "is-active": isHowItWorks }}
        aria-current={isHowItWorks ? "page" : undefined}
      >
        How It Works
      </a>
      <a
        href="/about/"
        class:list={{ "is-active": isAbout }}
        aria-current={isAbout ? "page" : undefined}
      >
        About
      </a>
      <a
        href="/strong-circle/"
        class:list={{ "is-active": isStrongCircle }}
        aria-current={isStrongCircle ? "page" : undefined}
      >
        Strong Circle
      </a>
      <a
        href="/ways-to-support/"
        class:list={{ "is-active": isWaysToSupport }}
        aria-current={isWaysToSupport ? "page" : undefined}
      >
        Support
      </a>
      <a href={homeHref("#contact")}>Contact</a>
    </div>
    <div class="nav-actions">
      <a class="pill primary" href={homeHref("#donate")} aria-label="Fund recovery care">
        <span class="nav-action-label">Fund recovery care</span>
      </a>
    </div>
  </nav>
</header>
