---
import DonationModule from "./DonationModule.astro";

interface DonateContent {
  heading: string;
  lead: string;
  outcomes: string;
  goalLabel: string;
  goalAmount: string;
  goalCopy: string;
  covers: {
    eyebrow: string;
    items: Array<{ heading: string; body: string }>;
  };
}

interface Props {
  chapter?: string;
  donate: DonateContent;
}

const { chapter, donate } = Astro.props;
---

<!-- Inline GiveButter donation widget -->
<script is:inline>
  // Load GiveButter widget script
  (function() {
    const script = document.createElement('script');
    script.async = true;
    script.src = 'https://widgets.givebutter.com/latest.umd.cjs?acct=n8kZx5v2K1qF9Qh7&p=other';
    document.head.appendChild(script);
  })();
</script>

<section class="donate-section story-ask" id="donate" data-chapter={chapter}>
  <div class="donate-wrap">
    <div>
      <h2 data-reveal>{donate.heading}</h2>
      <p class="lead" data-reveal>{donate.lead}</p>
      <p class="outcomes" data-reveal>{donate.outcomes}</p>

      <div class="goal-panel" role="group" aria-label="Fundraising goal" data-reveal>
        <div class="goal-top">
          <span>{donate.goalLabel}</span>
          <span>{donate.goalAmount}</span>
        </div>
        <div class="goal-bar" aria-hidden="true">
          <div class="goal-fill"></div>
        </div>
        <p class="goal-copy">{donate.goalCopy}</p>
      </div>
    </div>

    <div data-reveal>
      <!-- Primary GiveButter inline widget -->
      <div class="givebutter-widget-container">
        <givebutter-widget id="22strong-donate"></givebutter-widget>
        <style>
          .givebutter-widget-container {
            width: 100%;
            min-height: 500px;
            border-radius: var(--radius);
            overflow: hidden;
            background: rgba(255, 253, 247, 0.98);
            box-shadow: var(--shadow-panel);
          }
          givebutter-widget {
            display: block;
            width: 100%;
            min-height: 500px;
          }
        </style>
      </div>
      <!-- Fallback to custom donation module if GiveButter doesn't load -->
      <noscript>
        <DonationModule />
      </noscript>
    </div>
  </div>

  <div class="donate-covers" data-reveal>
    <span class="eyebrow">{donate.covers.eyebrow}</span>
    <ul class="donate-covers-grid">
      {donate.covers.items.map((item) => (
        <li>
          <strong>{item.heading}</strong>
          <span>{item.body}</span>
        </li>
      ))}
    </ul>
  </div>
</section>
