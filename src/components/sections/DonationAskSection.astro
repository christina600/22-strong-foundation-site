---
import { Image } from "astro:assets";
import DonationModule from "./DonationModule.astro";
import { getImageByPath } from "../../assets/images";

interface DonateStoryImage {
  src: string;
  alt: string;
  caption?: string;
  imagePosition?: string;
}

interface DonateFeaturedTestimonial {
  quote: string;
  name: string;
  title?: string;
  photo: string;
  photoAlt?: string;
}

interface DonateContent {
  heading: string;
  lead: string;
  outcomes: string;
  storyImage?: DonateStoryImage;
  featuredTestimonial?: DonateFeaturedTestimonial;
}

interface Props {
  chapter?: string;
  donate: DonateContent;
}

const { chapter, donate } = Astro.props;
const featured = donate.featuredTestimonial;
const featuredAsset = featured ? getImageByPath(featured.photo) : undefined;
---

<section class="donate-section story-ask" id="donate" data-chapter={chapter}>
  <div class="donate-wrap">
    <div class="donate-intro">
      <h2 data-reveal>{donate.heading}</h2>
      <p class="lead" data-reveal>{donate.lead}</p>
      {donate.outcomes && <p class="outcomes" data-reveal>{donate.outcomes}</p>}
    </div>

    <div class="donate-action" data-reveal>
      {featured && (
        <figure class="donate-voice">
          {featuredAsset
            ? <Image
                class="donate-voice__photo"
                src={featuredAsset}
                alt={featured.photoAlt ?? featured.name}
                width={480}
                height={320}
                loading="lazy"
                decoding="async"
                fetchpriority="low"
              />
            : <img
                class="donate-voice__photo"
                src={featured.photo}
                alt={featured.photoAlt ?? featured.name}
                width="480"
                height="320"
                loading="lazy"
                decoding="async"
              />}
          <blockquote class="donate-voice__quote">{featured.quote}</blockquote>
          <figcaption class="donate-voice__cite">
            {featured.name}{featured.title ? ` · ${featured.title}` : ""}
          </figcaption>
        </figure>
      )}
      <DonationModule />
      <p class="donate-circle-note">
        Prefer monthly? That's the <a href="/ways-to-support/#strong-circle">Strong Circle</a>.
      </p>
    </div>
  </div>
</section>

<style>
  .donate-voice {
    display: grid;
    gap: 14px;
    margin: 0 0 26px;
    padding: 0;
    justify-items: start;
    max-width: 420px;
  }

  .donate-voice__photo {
    width: 100%;
    max-width: 340px;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    object-position: 32% center;
    border-radius: 14px;
  }

  .donate-voice__quote {
    margin: 0;
    font-size: clamp(1.35rem, 2vw, 1.7rem);
    font-weight: 640;
    line-height: 1.32;
    text-wrap: balance;
  }

  .donate-voice__quote::before { content: "\201C"; }
  .donate-voice__quote::after { content: "\201D"; }

  .donate-voice__cite {
    font-size: 1.25rem;
    font-weight: 700;
    opacity: .78;
  }
</style>
