---
import { Image } from "astro:assets";
import DonationModule from "./DonationModule.astro";
import { getImageByPath } from "../../assets/images";

interface DonateStoryImage {
  src: string;
  alt: string;
  caption?: string;
  imagePosition?: string;
}

interface DonateContent {
  heading: string;
  lead: string;
  outcomes: string;
  goalLabel: string;
  goalAmount: string;
  goalCopy: string;
  givingCards?: Array<{ amount: string; body: string }>;
  storyImage?: DonateStoryImage;
  covers: {
    eyebrow: string;
    items: Array<{ heading: string; body: string }>;
  };
}

interface Props {
  chapter?: string;
  donate: DonateContent;
}

const { chapter, donate } = Astro.props;
---

<section class="donate-section story-ask" id="donate" data-chapter={chapter}>
  <div class="donate-wrap">
    <div>
      <h2 data-reveal>{donate.heading}</h2>
      <p class="lead" data-reveal>{donate.lead}</p>
      {donate.outcomes && <p class="outcomes" data-reveal>{donate.outcomes}</p>}

      <div class="goal-panel" role="group" aria-label="Fundraising goal" data-reveal>
        <div class="goal-top">
          <span>{donate.goalLabel}</span>
          <strong>{donate.goalAmount}</strong>
        </div>
        <div class="goal-bar" aria-hidden="true">
          <div class="goal-fill"></div>
        </div>
        <p class="goal-copy">{donate.goalCopy}</p>
      </div>

      {donate.givingCards && donate.givingCards.length > 0 && (
        <div class="giving-cards" aria-label="What different gifts make possible" data-reveal>
          {donate.givingCards.map((card) => (
            <article class="giving-card">
              <strong>{card.amount}</strong>
              <span>{card.body}</span>
            </article>
          ))}
        </div>
      )}

      {donate.storyImage && (
        <figure class="donate-proof-photo" data-reveal>
          {(() => {
            const asset = getImageByPath(donate.storyImage.src);
            return asset
              ? <Image
                  src={asset}
                  alt={donate.storyImage.alt}
                  width={900}
                  height={560}
                  loading="lazy"
                  decoding="async"
                  fetchpriority="low"
                  sizes="(max-width: 920px) 92vw, 48vw"
                  widths={[560, 760, 900, 1200]}
                  style={donate.storyImage.imagePosition ? `object-position: ${donate.storyImage.imagePosition};` : undefined}
                />
              : <img
                  src={donate.storyImage.src}
                  alt={donate.storyImage.alt}
                  width="900"
                  height="560"
                  loading="lazy"
                  decoding="async"
                  fetchpriority="low"
                  style={donate.storyImage.imagePosition ? `object-position: ${donate.storyImage.imagePosition};` : undefined}
                />;
          })()}
          {donate.storyImage.caption && <figcaption>{donate.storyImage.caption}</figcaption>}
        </figure>
      )}
    </div>

    <div data-reveal>
      <DonationModule />
    </div>
  </div>

  <div class="donate-covers" data-reveal>
    <ul class="donate-covers-grid">
      {donate.covers.items.map((item) => (
        <li>
          <strong>{item.heading}</strong>
          <span>{item.body}</span>
        </li>
      ))}
    </ul>
  </div>
</section>
