---
/**
 * Donation Module — the interactive giving widget.
 *
 * Donation widget used on the single-scroll homepage. Until the secure giving
 * URL is configured, the primary action routes donors to the contact section.
 */

import site from "../../content/site.json";
import strings from "../../content/strings/en.json";
import { isConfigured } from "../../utils/config";

type DonationImpactMap = {
  monthly?: Record<string, string>;
  oneTime?: Record<string, string>;
};

const amounts = site.donationAmounts.length ? site.donationAmounts : [22, 100, 250, 1000];
const defaultAmountIndex = Math.min(Math.max(site.defaultAmountIndex, 0), amounts.length - 1);
const defaultAmount = amounts[defaultAmountIndex] ?? 100;
const formatAmount = (amount: number) => Number(amount).toLocaleString();

// Per-amount impact copy. The script (donation.ts) reads this map from the
// data attribute below and swaps the impact line as the donor changes amount
// or frequency. {amount} is replaced live; "default" covers custom amounts.
const impact = site.donationImpact as DonationImpactMap;
const monthlyImpact = impact.monthly ?? {};
const initialImpactTemplate =
  monthlyImpact[String(defaultAmount)] ?? monthlyImpact.default ?? "Your gift helps turn a stalled recovery plan into real appointments.";
const initialImpactDetail = String(initialImpactTemplate).replace(/\{amount\}/g, Number(defaultAmount).toLocaleString());

// The online giving platform is pending. Until donateUrl is configured, route
// the give button to the contact section rather than emitting a broken link.
const donateReady = isConfigured(site.donateUrl);
const donateHref = donateReady ? site.donateUrl : "#contact";
const donateLabel = donateReady ? strings.donation.continueToCheckout : "Send a giving note";
---

<div class="donation-module" data-impact-map={JSON.stringify(impact)} data-default-amount={defaultAmount}>
  <div class="card donation-card-main">
    <span class="eyebrow">{strings.donation.giveNow}</span>
    <div class="toggle-row" role="group" aria-label={strings.donation.giftFrequency}>
      <button type="button" class="active" data-frequency="monthly" aria-pressed="true">
        <span class="most-impact-badge">{strings.donation.mostImpact}</span>
        {strings.donation.monthly}
      </button>
      <button type="button" data-frequency="one-time" aria-pressed="false">{strings.donation.oneTime}</button>
    </div>
    <span class="eyebrow amount-grid-label">Suggested gift amounts</span>
    <div class="amount-grid" role="group" aria-label={strings.donation.giftAmountOptions}>
      {amounts.map((amount, index) => (
        <button
          type="button"
          class={`amount-button ${index === defaultAmountIndex ? "active" : ""}`}
          data-amount={amount}
          aria-pressed={index === defaultAmountIndex ? "true" : "false"}
        >
          ${formatAmount(amount)}
        </button>
      ))}
    </div>
    <div class="other-amount-row">
      <input
        type="number"
        inputmode="decimal"
        min="1"
        step="any"
        class="other-amount-input"
        placeholder={strings.donation.otherAmount}
        aria-label={strings.donation.customAmountLabel}
      />
    </div>
    <div class="impact-line" role="status" aria-live="polite" aria-atomic="true">
      <span class="eyebrow" data-label-monthly={strings.donation.yourImpact} data-label-onetime={strings.donation.yourImpactOneTime}>{strings.donation.yourImpact}</span>
      <strong class="gift-summary">${formatAmount(defaultAmount)}/mo</strong>
      <span class="gift-detail">{initialImpactDetail}</span>
      <small>Monthly gift. Annual commitment: ${formatAmount(defaultAmount * 12)}.</small>
    </div>
    <a class="btn-donate" href={donateHref} data-donate-base={donateReady ? site.donateUrl : undefined} aria-label={donateLabel}>
      {donateLabel} &rarr;
    </a>
    {donateReady && <p class="donation-footnote">{strings.donation.footnote}</p>}
    <p class="donation-legal">
      {site.orgName} &middot; {site.taxStatus} &middot; EIN {site.ein} &middot; Tax-deductible.
    </p>
  </div>
</div>
