---
/**
 * Donation Module — the interactive giving widget.
 *
 * One widget, two distinct asks. It defaults to one-time giving (the Donate
 * section's "act now" ask) with its own ladder; monthly giving (the Strong
 * Circle relationship) has its own ladder and is reached via the Strong Circle
 * modal, which presets this widget to monthly $22. Until the secure giving URL
 * is configured, the primary action routes donors to the contact section.
 */

import site from "../../content/site.json";
import strings from "../../content/strings/en.json";
import { isConfigured } from "../../utils/config";

interface Props {
  defaultFrequency?: "monthly" | "one-time";
}
const { defaultFrequency = "one-time" } = Astro.props;

type DonationImpactMap = {
  monthly?: Record<string, string>;
  oneTime?: Record<string, string>;
};

const sets = site.donationAmountSets;
const defaults = site.donationDefaults;
const impact = site.donationImpact as DonationImpactMap;
const fmt = (amount: number) => Number(amount).toLocaleString();

const grids = [
  { freq: "one-time" as const, amounts: sets.oneTime, def: defaults.oneTime },
  { freq: "monthly" as const, amounts: sets.monthly, def: defaults.monthly },
];

const isMonthly = defaultFrequency === "monthly";
const initAmount = isMonthly ? defaults.monthly : defaults.oneTime;
const initMap = (isMonthly ? impact.monthly : impact.oneTime) ?? {};
const initTemplate =
  initMap[String(initAmount)] ?? initMap.default ?? "Your gift helps turn a stalled recovery plan into real appointments.";
const initDetail = String(initTemplate).replace(/\{amount\}/g, fmt(initAmount)).replace(/\{annual\}/g, fmt(initAmount * 12));

// Online giving platform pending: route to contact until donateUrl is set.
const donateReady = isConfigured(site.donateUrl);
const donateHref = donateReady ? site.donateUrl : "#contact";
const donateLabel = donateReady ? strings.donation.continueToCheckout : "Send a giving note";
---

<div
  class="donation-module"
  data-frequency={defaultFrequency}
  data-default-monthly={defaults.monthly}
  data-default-onetime={defaults.oneTime}
  data-impact-map={JSON.stringify(impact)}
>
  <div class="card donation-card-main">
    <span class="eyebrow">{strings.donation.giveNow}</span>
    <div class="toggle-row" role="group" aria-label={strings.donation.giftFrequency}>
      <button type="button" class={defaultFrequency === "one-time" ? "active" : ""} data-frequency="one-time" aria-pressed={defaultFrequency === "one-time" ? "true" : "false"}>{strings.donation.oneTime}</button>
      <button type="button" class={defaultFrequency === "monthly" ? "active" : ""} data-frequency="monthly" aria-pressed={defaultFrequency === "monthly" ? "true" : "false"}>{strings.donation.monthly}</button>
    </div>
    <span class="eyebrow amount-grid-label">Suggested gift amounts</span>
    {grids.map((g) => (
      <div class="amount-grid" data-grid={g.freq} role="group" aria-label={strings.donation.giftAmountOptions}>
        {g.amounts.map((amount) => (
          <button
            type="button"
            class={`amount-button ${amount === g.def ? "active" : ""}`}
            data-amount={amount}
            aria-pressed={amount === g.def ? "true" : "false"}
          >
            ${fmt(amount)}
          </button>
        ))}
      </div>
    ))}
    <div class="other-amount-row">
      <input
        type="number"
        inputmode="decimal"
        min="1"
        step="any"
        class="other-amount-input"
        placeholder={strings.donation.otherAmount}
        aria-label={strings.donation.customAmountLabel}
      />
    </div>
    <div class="impact-line" role="status" aria-live="polite" aria-atomic="true">
      <span class="eyebrow" data-label-monthly={strings.donation.yourImpact} data-label-onetime={strings.donation.yourImpactOneTime}>{isMonthly ? strings.donation.yourImpact : strings.donation.yourImpactOneTime}</span>
      <strong class="gift-summary">{isMonthly ? `$${fmt(initAmount)}/mo` : `$${fmt(initAmount)}`}</strong>
      <span class="gift-detail">{initDetail}</span>
      <small>{isMonthly ? `Monthly gift. Annual commitment: $${fmt(initAmount * 12)}.` : "One-time gift."}</small>
    </div>
    <a class="btn-donate" href={donateHref} data-donate-base={donateReady ? site.donateUrl : undefined} aria-label={donateLabel}>
      {donateLabel} &rarr;
    </a>
    {donateReady && <p class="donation-footnote">{strings.donation.footnote}</p>}
    <p class="donation-legal">
      {site.orgName} &middot; {site.taxStatus} &middot; EIN {site.ein} &middot; Tax-deductible.
    </p>
  </div>
</div>
