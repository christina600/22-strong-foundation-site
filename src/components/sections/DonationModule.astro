---
/**
 * Donation Module — the interactive giving widget.
 *
 * The Donate section's one-time giving widget. Monthly membership now lives
 * on the dedicated Strong Circle page so the two donor asks stay distinct.
 */

import site from "../../content/site.json";
import strings from "../../content/strings/en.json";
import { isConfigured } from "../../utils/config";

interface Props {
  defaultFrequency?: "monthly" | "one-time";
  showFrequencyToggle?: boolean;
}
const { defaultFrequency = "one-time", showFrequencyToggle = false } = Astro.props;

type DonationImpactMap = {
  monthly?: Record<string, string>;
  oneTime?: Record<string, string>;
};

const sets = site.donationAmountSets;
const defaults = site.donationDefaults;
const impact = site.donationImpact as DonationImpactMap;
const fmt = (amount: number) => Number(amount).toLocaleString();

const activeDefaultFrequency = showFrequencyToggle ? defaultFrequency : "one-time";
const grids = showFrequencyToggle
  ? [
      { freq: "one-time" as const, amounts: sets.oneTime, def: defaults.oneTime },
      { freq: "monthly" as const, amounts: sets.monthly, def: defaults.monthly },
    ]
  : [
      { freq: "one-time" as const, amounts: sets.oneTime, def: defaults.oneTime },
    ];

const isMonthly = activeDefaultFrequency === "monthly";
const initAmount = isMonthly ? defaults.monthly : defaults.oneTime;
const amountNotes: Record<"monthly" | "one-time", Record<number, string>> = {
  monthly: {
    22: "Strong Circle",
    50: "Follow-through care",
    100: "Plans moving",
    190: "Monthly session",
  },
  "one-time": {
    22: "helps keep the next appointment within reach",
    50: "helps offset care",
    100: "Offset care",
    190: "funds one session",
    850: "supports an average care plan",
  },
};
const amountNote = (frequency: "monthly" | "one-time", amount: number) => amountNotes[frequency][amount] ?? "Recovery care";

// One-time gifts check out to the Fund Recovery Care campaign.
const oneTimeReady = isConfigured(site.donateUrl);
const monthlyReady = isConfigured(site.strongCircleUrl);
const oneTimeUrl = oneTimeReady ? site.donateUrl : undefined;
const monthlyUrl = monthlyReady ? site.strongCircleUrl : undefined;
const initReady = isMonthly ? monthlyReady : oneTimeReady;
const checkoutFrequency = isMonthly ? "monthly" : "once";
const checkoutBase = isMonthly ? monthlyUrl : oneTimeUrl;
const donateHref = checkoutBase
  ? `${checkoutBase}${checkoutBase.includes("?") ? "&" : "?"}amount=${encodeURIComponent(initAmount)}&frequency=${checkoutFrequency}`
  : "#contact";
const initLabelTemplate = isMonthly ? strings.donation.checkoutMonthly : strings.donation.checkoutOneTime;
const donateLabel = initReady ? initLabelTemplate.replace("{amount}", `$${fmt(initAmount)}`) : strings.donation.giveNow;
---

<div
  class="donation-module"
  data-frequency={activeDefaultFrequency}
  data-default-monthly={defaults.monthly}
  data-default-onetime={defaults.oneTime}
  data-impact-map={JSON.stringify(impact)}
>
  <div class="card donation-card-main">
    <div class="donation-card-header">
      <span class="donation-type">{strings.donation.oneTimeGift}</span>
      <span class="donation-secure">{strings.donation.secureCheckout}</span>
    </div>
    <h3 class="donation-card-title">{strings.donation.cardTitle}</h3>
    <p class="donation-card-intro">{strings.donation.cardIntro}</p>
    {showFrequencyToggle && (
      <div class="toggle-row" role="group" aria-label={strings.donation.giftFrequency}>
        <button type="button" class={activeDefaultFrequency === "one-time" ? "active" : ""} data-frequency-control data-frequency="one-time" aria-pressed={activeDefaultFrequency === "one-time" ? "true" : "false"}>{strings.donation.oneTime}</button>
        <button type="button" class={activeDefaultFrequency === "monthly" ? "active" : ""} data-frequency-control data-frequency="monthly" aria-pressed={activeDefaultFrequency === "monthly" ? "true" : "false"}>{strings.donation.monthly}</button>
      </div>
    )}
    <span class="eyebrow amount-grid-label">{strings.donation.amountGridLabel}</span>
    {grids.map((g) => (
      <div class="amount-grid" data-grid={g.freq} role="group" aria-label={strings.donation.giftAmountOptions}>
        {g.amounts.map((amount) => (
          <button
            type="button"
            class={`amount-button ${amount === g.def ? "active" : ""}`}
            data-amount={amount}
            data-featured={g.freq === "one-time" && amount === 190 ? "true" : undefined}
            aria-pressed={amount === g.def ? "true" : "false"}
          >
            <span class="amount-button-value">${fmt(amount)}</span>
            <small>{amountNote(g.freq, amount)}</small>
          </button>
        ))}
      </div>
    ))}
    <div class="other-amount-row">
      <input
        type="number"
        inputmode="decimal"
        min="1"
        step="any"
        class="other-amount-input"
        placeholder={strings.donation.otherAmount}
        aria-label={strings.donation.customAmountLabel}
      />
    </div>
    <a
      class="btn-donate"
      href={donateHref}
      data-donate-onetime={oneTimeUrl}
      data-donate-monthly={showFrequencyToggle ? monthlyUrl : undefined}
      data-label-onetime={strings.donation.checkoutOneTime}
      data-label-monthly={strings.donation.checkoutMonthly}
      aria-label={donateLabel}
    >
      {donateLabel}
    </a>
    {(oneTimeReady || monthlyReady) && <p class="donation-footnote">{strings.donation.footnote}</p>}
    <p class="donation-legal">
      {site.orgName} &middot; {site.taxStatus} &middot; EIN {site.ein} &middot; Tax-deductible.
    </p>
  </div>
</div>
