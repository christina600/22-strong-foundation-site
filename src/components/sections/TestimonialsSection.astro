---
import type { AudienceGroupContent } from "../../utils/home-story";
import VoiceCard from "./VoiceCard.astro";

interface Props {
  groups: AudienceGroupContent[];
}

const { groups } = Astro.props;

const videoCards = groups.flatMap((group) =>
  (group.videos ?? []).map((video, index) => ({
    id: `${group.id}-video-${index}`,
    type: "video" as const,
    video
  }))
);
// Voices ordered athletes-first so Adam (with his photo) lands right after the
// video; the sample veteran cards follow.
const voiceCards = [...groups].reverse().flatMap((group) =>
  group.voices.map((voice, index) => ({
    id: `${group.id}-voice-${index}`,
    type: "voice" as const,
    voice
  }))
);
const testimonialCards = [...videoCards, ...voiceCards];
const testimonialGroups = groups.filter((group) => (group.videos && group.videos.length > 0) || group.voices.length > 0);
const testimonialReelId = testimonialGroups.find((group) => group.voicesId)?.voicesId ?? "testimonials";
const testimonialAriaLabel = testimonialGroups.map((group) => group.voicesAriaLabel).join(" and ") || "Recovery testimonials";
---

{testimonialCards.length > 0 && (
  <section class="audience-voices audience-voices--combined" id={testimonialReelId} aria-label={testimonialAriaLabel}>
    <div class="veteran-voices veteran-voices--with-video testimonial-reel" data-testimonial-reel>
      <div class="testimonial-reel-shell">
        <div
          class="vv-grid testimonial-reel-track"
          data-testimonial-reel-track
          tabindex="0"
          aria-label={testimonialAriaLabel}
        >
          {testimonialCards.map((card, index) => (
            <div class="testimonial-reel-slide" data-testimonial-slide data-slide-index={index}>
              {card.type === "video" ? <VoiceCard video={card.video} /> : <VoiceCard voice={card.voice} />}
            </div>
          ))}
        </div>

        <div class="testimonial-reel-chrome" aria-label="Testimonial controls">
          <button class="testimonial-reel-button" type="button" data-testimonial-prev aria-label="Previous testimonial">
            <span aria-hidden="true">&larr;</span>
          </button>
          <div class="testimonial-reel-dots" aria-label="Testimonial slide position">
            {testimonialCards.map((_, index) => (
              <button
                class="testimonial-reel-dot"
                type="button"
                data-testimonial-dot
                data-slide-index={index}
                aria-label={`Go to testimonial ${index + 1}`}
              />
            ))}
          </div>
          <button class="testimonial-reel-button" type="button" data-testimonial-next aria-label="Next testimonial">
            <span aria-hidden="true">&rarr;</span>
          </button>
        </div>
      </div>
    </div>
  </section>
)}
