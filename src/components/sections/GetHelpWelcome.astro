---
/**
 * Get Help Welcome — concern cards + digital safety alert.
 * The digital safety alert is placed FIRST (before concern cards)
 * so visitors on monitored devices see it immediately.
 */

import SectionShell from "../ui/SectionShell.astro";
---

<SectionShell
  eyebrow="You are welcome here"
  title="Three things people often worry about. Here are the answers."
  body="You can call even if you are not sure what you need yet."
>
  <div class="alert-note">
    <strong>Digital safety:</strong> Your device may store browsing history.
    Manually clear browser history afterward if it is safe to do so.
    Clearing history may not hide activity from every device, account,
    or monitoring tool.
  </div>
  <div class="grid three">
    <div class="card">
      <h3>TEMPLATE: Concern 1</h3>
      <p>TEMPLATE: Direct answer — e.g. about children, dependents, or family members.</p>
    </div>
    <div class="card">
      <h3>TEMPLATE: Concern 2</h3>
      <p>TEMPLATE: Direct answer — e.g. about pets, belongings, or practical needs.</p>
    </div>
    <div class="card">
      <h3>TEMPLATE: Concern 3</h3>
      <p>TEMPLATE: Direct answer — e.g. about identity, documentation, or eligibility.</p>
    </div>
  </div>
</SectionShell>
