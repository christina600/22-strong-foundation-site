---
/**
 * Financial Cards — Form 990, audited financials, registry/ratios.
 */

import SectionShell from "../ui/SectionShell.astro";
import site from "../../content/site.json";
---

<SectionShell
  eyebrow="Financial transparency"
  title="TEMPLATE: Financial transparency headline"
  body="TEMPLATE: Explain what donors will find here — filings, audited statements, registration details, and contacts."
>
  <div class="grid three">
    <div class="card"><h3>Form 990 filings</h3><p>TEMPLATE: List recent Form 990 filing years. Link to ProPublica Nonprofit Explorer and Candid when live.</p><span class="tag">IRS filings</span></div>
    <div class="card"><h3>Audited Financials</h3><p>TEMPLATE: Most recent audited financial statement. Describe your audit process.</p><span class="tag">TEMPLATE: Year</span></div>
    <div class="card"><h3>Registry and ratios</h3><p>EIN {site.ein}. {site.stateRegistration}. TEMPLATE: Fiscal year dates. TEMPLATE: Program expense ratio.</p><span class="tag">Verification</span></div>
  </div>
  <div class="trust-note">
    <strong>Disclosure fields:</strong> {site.orgName}. {site.taxStatus}. EIN {site.ein}. {site.stateRegistration}. Founded {site.foundedYear}. Financial questions: {site.email}.
  </div>
</SectionShell>
