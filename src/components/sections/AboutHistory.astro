---
/**
 * About History — founding story told in a split-pane layout.
 * Uses SplitPane for 50/50 image + text visual variety.
 */

import SplitPane from "../ui/SplitPane.astro";
---

<SplitPane
  eyebrow="History"
  title="TEMPLATE: History headline"
  body="TEMPLATE: Two or three sentences on your founding story — when, where, by whom, and what need it addressed."
  imageLabel="TEMPLATE: Describe the image accessibly — e.g. photo of original office or founding team."
  imageRight={true}
>
  <div class="grid two" style="margin-top: var(--space-5);">
    <div class="card"><h3>Then</h3><p>TEMPLATE: Describe what the organization looked like at its founding.</p></div>
    <div class="card"><h3>Now</h3><p>TEMPLATE: Describe the organization today — services offered, people served, and service area.</p></div>
  </div>
</SplitPane>
