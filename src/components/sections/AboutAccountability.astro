---
/**
 * About Accountability — tax status, registration, financials, transparency cards.
 */

import SectionShell from "../ui/SectionShell.astro";
import site from "../../content/site.json";
---

<SectionShell
  eyebrow="04 / Accountability"
  title="Open books."
  body="Legitimacy should be visible without sending donors on a scavenger hunt."
>
  <div class="grid four">
    <div class="card"><h3>Tax status</h3><p>{site.taxStatus}. EIN {site.ein}.</p></div>
    <div class="card"><h3>Registration</h3><p>{site.stateRegistration}.</p></div>
    <div class="card">
      <h3>Financials</h3>
      <p>Audited financials, Form 990, and disclosures should be easy to find.</p>
      <a class="card-link" href="/financials">View disclosures &rarr;</a>
    </div>
    <div class="card"><h3>Transparency</h3><p>Use verified transparency seals, audit notes, and reporting periods only when current.</p></div>
  </div>
</SectionShell>
