---
/**
 * Impact — key outcome metrics in a tile grid, animated with count-up.
 * Numbers reflect the organization's most recent reporting period;
 * replace with verified figures from your annual report before launch.
 */

import SectionShell from "../ui/SectionShell.astro";
import strings from "../../content/strings/en.json";
---

<SectionShell
  eyebrow="Our impact"
  title="The mission, measured."
  body="Figures reflect our most recent 12-month reporting period. Full numbers and financials are published in our annual disclosures."
>
  <div class="audit-grid">
    <div class="audit-tile"><strong>TEMPLATE: Number</strong><span>TEMPLATE: What it measures</span></div>
    <div class="audit-tile"><strong>TEMPLATE: Number</strong><span>TEMPLATE: What it measures</span></div>
    <div class="audit-tile"><strong>TEMPLATE: Number</strong><span>TEMPLATE: What it measures</span></div>
    <div class="audit-tile"><strong>TEMPLATE: Number</strong><span>TEMPLATE: What it measures</span></div>
    <div class="audit-tile"><strong>TEMPLATE: Number</strong><span>TEMPLATE: What it measures</span></div>
  </div>
  <div class="button-row">
    <a class="btn-outline" href="/financials#impact-reports">{strings.sections.seeImpact}</a>
    <a class="btn-outline" href="/financials">{strings.sections.financialDisclosures}</a>
  </div>
</SectionShell>

<script>
  import "../../scripts/count-up.ts";
</script>
