---
import type { EvidenceStatContent } from "../../utils/home-story";

interface Props {
  stat: EvidenceStatContent;
  variant: "about" | "audience";
  reveal?: boolean;
}

const { stat, variant, reveal = false } = Astro.props;
const revealAttrs = reveal ? { "data-reveal": "" } : {};
// Long/multi-word numbers (e.g. "4.6 million") overflow the narrow side
// column, so stack them above their copy instead of beside it.
const isStacked = variant === "audience" && /\s/.test(stat.number.trim());
const className = variant === "about"
  ? `about-evidence-stat${stat.light ? " is-light" : ""}`
  : `audience-stat${stat.light ? " is-light" : ""}${isStacked ? " is-stacked" : ""}`;

// Extract numeric value for animation (handles "4.6 million", "38%", "$190", etc.)
const extractNumericValue = (text: string): { value: number; prefix: string; suffix: string } => {
  const cleaned = text.trim();
  let prefix = "";
  let suffix = "";
  let value = 0;
  
  // Extract prefix ($, etc.)
  if (/^[$£€]/.test(cleaned)) {
    prefix = cleaned[0];
  }
  
  // Extract suffix (%, million, etc.)
  const suffixMatch = cleaned.match(/\s*(%|million|thousand|billion|k|m|b)\s*$/i);
  if (suffixMatch) {
    suffix = suffixMatch[1];
  }
  
  // Extract numeric part
  const numMatch = cleaned.match(/[$£€]?(\d+\.?\d*)/);
  if (numMatch) {
    value = parseFloat(numMatch[1]);
  }
  
  return { value, prefix, suffix };
};

const { value: numericValue, prefix, suffix } = extractNumericValue(stat.number);
const hasNumeric = numericValue > 0 && !/\s/.test(stat.number.replace(/[$£€%]/g, "").trim());
---

{variant === "about" ? (
  <aside class={className} role="listitem" {...revealAttrs}>
    <div 
      class="about-evidence-number" 
      data-counter={hasNumeric ? "" : undefined}
      data-counter-target={hasNumeric ? numericValue : undefined}
      data-counter-prefix={hasNumeric ? prefix : undefined}
      data-counter-suffix={hasNumeric ? suffix : undefined}
    >
      {stat.number}
    </div>
    <div class="about-evidence-copy">
      <p>{stat.text}</p>
      <span class="about-evidence-source">
        <a href={stat.url} target="_blank" rel="noopener noreferrer">{stat.source}</a>
      </span>
    </div>
  </aside>
) : (
  <aside class={className} role="listitem" {...revealAttrs}>
    <div class="audience-stat-inner">
      <div 
        class="audience-stat-number"
        data-counter={hasNumeric ? "" : undefined}
        data-counter-target={hasNumeric ? numericValue : undefined}
        data-counter-prefix={hasNumeric ? prefix : undefined}
        data-counter-suffix={hasNumeric ? suffix : undefined}
      >
        {stat.number}
      </div>
      <div class="audience-stat-text">
        <p>{stat.text}</p>
        <span class="audience-stat-source">
          <a href={stat.url} target="_blank" rel="noopener noreferrer">{stat.source}</a>
        </span>
      </div>
    </div>
  </aside>
)}
