---
import type { EvidenceStatContent } from "../../utils/home-story";
import StatNumber from "./StatNumber.astro";

interface Props {
  stat: EvidenceStatContent;
  variant: "about" | "audience";
  reveal?: boolean;
}

const { stat, variant, reveal = false } = Astro.props;
const revealAttrs = reveal ? { "data-reveal": "" } : {};
// Long/multi-word numbers can overflow the narrow side
// column, so stack them above their copy instead of beside it.
const isStacked = variant === "audience" && /\s/.test(stat.number.trim());
const className = variant === "about"
  ? `about-evidence-stat${stat.light ? " is-light" : ""}`
  : `audience-stat${stat.light ? " is-light" : ""}${isStacked ? " is-stacked" : ""}`;
---

{variant === "about" ? (
  <aside class={className} role="listitem" {...revealAttrs}>
    <div class="about-evidence-number">
      <StatNumber text={stat.number} />
    </div>
    <div class="about-evidence-copy">
      <p>{stat.text}</p>
      {stat.source && (
        <span class="about-evidence-source">
          {stat.url
            ? <a href={stat.url} target="_blank" rel="noopener noreferrer">{stat.source}</a>
            : stat.source}
        </span>
      )}
    </div>
  </aside>
) : (
  <aside class={className} role="listitem" {...revealAttrs}>
    <div class="audience-stat-inner">
      <div class="audience-stat-number">
        <StatNumber text={stat.number} />
      </div>
      <div class="audience-stat-text">
        <p>{stat.text}</p>
        {stat.source && (
          <span class="audience-stat-source">
            {stat.url
              ? <a href={stat.url} target="_blank" rel="noopener noreferrer">{stat.source}</a>
              : stat.source}
          </span>
        )}
      </div>
    </div>
  </aside>
)}
