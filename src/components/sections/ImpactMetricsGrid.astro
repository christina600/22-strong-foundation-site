---
/**
 * Impact Metrics Grid — shared metrics display used by ImpactPreview and ImpactMetrics.
 * Reads from impact.json.
 */

import impactMetrics from "../../content/impact.json";
import strings from "../../content/strings/en.json";
---

<div class="metrics">
  {impactMetrics.map((metric) => (
    <div class="metric">
      <strong>{metric.number}</strong>
      <span>{metric.label}</span>
    </div>
  ))}
</div>
<div class="button-row">
  <a class="btn-outline" href="/financials#impact-reports">{strings.sections.exploreImpact}</a>
  <a class="btn-outline" href="/financials">{strings.sections.financialTransparency}</a>
</div>

<script>
  import "../../scripts/count-up.ts";
</script>
