---
/**
 * Involvement Detail — supporter pathway for volunteer/partner/training pages.
 */

import SectionShell from "../ui/SectionShell.astro";
---

<SectionShell
  eyebrow="Supporter pathway"
  title="TEMPLATE: Supporter pathway headline"
  body="TEMPLATE: Explain that supporters should follow the organization process before volunteering, partnering, or donating."
>
  <div class="grid three">
    <div class="card"><h3>Requirements</h3><p>Volunteer and partner roles may require screening, training, confidentiality expectations, and role-specific guidance.</p></div>
    <div class="card"><h3>Time commitment</h3><p>Different opportunities require different levels of time, availability, training, and in-person or remote participation.</p></div>
    <div class="card"><h3>Next step</h3><p>Use the contact page, volunteer pathway, or donation page to take the next appropriate step.</p></div>
  </div>
</SectionShell>
