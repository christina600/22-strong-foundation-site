---
/**
 * Problem — the theory-of-change opener. Names the problem the org's
 * mission solves, sizes it with statistics, shows why it persists
 * (system gaps), and turns toward where the org comes in.
 *
 * CONTENT lives in src/content/problem.json — edit copy, numbers, and
 * source links there, no code required. This file is the STRUCTURE.
 *
 * Sagittarius lens: "The Big Thinker." A theory of change isn't an
 * optional extra — problem → system gaps → response is the spine that
 * makes the rest of the page make sense.
 *
 * Virgo lens: "The Craftsperson." <figure> not <article> for stat cards.
 * Ring %, bar %, and pictograph headline derive from one number each —
 * no second copy to drift.
 *
 * Aquarius lens: "The Innovator / Systems Thinker." The system gaps and
 * the response must argue at the same altitude — diagnose a system,
 * prescribe for the system. A human anchor keeps the statistics from
 * erasing the people they're about; flow connectors make problem → gap →
 * response read as one connected system.
 *
 * Scorpio lens: "The Investigator." Trust is earned, not asserted.
 * Citations link to a verifiable source; outcome claims carry a
 * methodology note; the human anchor gives the person their own voice.
 *
 * Capricorn lens: "The Strategist." Built to last, not just to launch.
 * Stats, gaps, and turn-steps are data-driven arrays (flex to any
 * count); a review-date marker makes the section self-governing; the
 * outcome stat carries a benchmark so the number has meaning.
 */

import SectionShell from "../ui/SectionShell.astro";
import StatCard from "./StatCard.astro";
import problem from "../../content/problem.json";
---

<SectionShell
  eyebrow={problem.eyebrow}
  title={problem.title}
  body={problem.body}
  extraClass="problem-section"
>
  <!-- ── STAT SHOWCASE ── data-driven: each entry in problem.json's
       `stats` array renders as one <figure> via StatCard. Add, remove,
       or reorder cards from the JSON; the bento grid reflows. ── -->
  <div class="stat-showcase">
    {problem.stats.map((stat) => <StatCard stat={stat} />)}
  </div>

  <!-- ── HUMAN ANCHOR ── a direct-voice quote so the section closes with
       the person speaking, not the org narrating for them. ── -->
  <blockquote class="problem-human">
    <p>{problem.humanAnchor.quote}</p>
    <footer>{problem.humanAnchor.attribution}</footer>
  </blockquote>

  <!-- Flow connector: the numbers don't move on their own → why. -->
  <div class="problem-flow" aria-hidden="true">
    <span class="problem-flow-line"></span>
    <span class="problem-flow-chevron">&darr;</span>
  </div>

  <!-- ── SYSTEM GAPS ── why the problem persists. Data-driven list —
       add or remove gaps in problem.json; the grid reflows. ── -->
  <div class="system-gaps">
    <h3 class="system-gaps-title">{problem.gapsTitle}</h3>
    <ol class="gap-list">
      {problem.gaps.map((gap, i) => (
        <li class="gap-item">
          <span class="gap-num" aria-hidden="true">{String(i + 1).padStart(2, "0")}</span>
          <div class="gap-body">
            <h4>{gap.heading}</h4>
            <p>{gap.body}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>

  <!-- Flow connector: the gaps → the org's response. -->
  <div class="problem-flow" aria-hidden="true">
    <span class="problem-flow-line"></span>
    <span class="problem-flow-chevron">&darr;</span>
  </div>

  <!-- ── THE TURN ── where the org comes in. The if → then → impact
       chain makes the causal logic explicit. Arrows between steps are
       CSS ::after — the chain is a clean data-driven <ol>. ── -->
  <div class="problem-turn">
    <p class="problem-turn-line">{problem.turn.line}</p>
    <ol class="turn-chain">
      {problem.turn.chain.map((step) => (
        <li class="turn-step">
          <span class="turn-step-tag">{step.tag}</span>
          <p>{step.text}</p>
        </li>
      ))}
    </ol>
    <!-- Acknowledged limits — candour earns trust. -->
    <p class="problem-turn-coda">{problem.turn.coda}</p>
  </div>

  <!-- ── REVIEW DATE ── makes the section self-governing: staff can see
       at a glance whether the data is due for a refresh. ── -->
  <p class="problem-reviewed">Data last reviewed: {problem.reviewedDate}</p>

  <!-- ── SECTION BRIDGE ── Libra: threads this section into the next
       (testimonials) so problem → people reads as one composition, not a
       hard cut. Shared motif, styled in sections.css. ── -->
  <div class="section-bridge" aria-hidden="true">
    <span class="section-bridge-line"></span>
    <span class="section-bridge-chevron">&darr;</span>
  </div>
</SectionShell>

<script>
  // Counts up .stat-figure-value numbers on scroll. Module is a
  // singleton, so importing it here too (alongside other sections)
  // runs the setup only once.
  import "../../scripts/count-up.ts";
  // Scroll-driven theory-of-change: flow connectors + the if→then→impact
  // chain activate as the section scrolls into focus. Singleton, only
  // binds when a .problem-section is present.
  import "../../scripts/problem-spine.ts";
</script>
