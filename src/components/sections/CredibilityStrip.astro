---
import { Image } from "astro:assets";
import dumbbellsRecovery from "../../assets/images/dumbbells-recovery.jpg";

interface Props {
  facts: string[];
  lead?: string;
}

const { facts, lead } = Astro.props;
---

<section class="credibility-strip story-proofline" aria-label="About 22 Strong Foundation">
  <ul class="credibility-strip-inner" data-scroll-reveal>
    {facts.map((fact) => <li class="credibility-strip-item">{fact}</li>)}
  </ul>
</section>

{lead && (
  <section class="recovery-feature" aria-label="Our recovery approach">
    <div class="recovery-feature-inner" data-scroll-reveal>
      <p class="recovery-feature-text">{lead}</p>
      <figure class="recovery-feature-figure">
        <Image
          src={dumbbellsRecovery}
          alt="An athlete lifting a dumbbell from the rack during a strength session"
          width={1002}
          height={904}
          loading="lazy"
          decoding="async"
          sizes="(max-width: 560px) 100vw, (max-width: 920px) 80vw, 50vw"
          widths={[480, 768, 1002]}
        />
      </figure>
    </div>
  </section>
)}
