---
/**
 * Revenue & Expense Breakdown — ratio bars and expense category card.
 */

import SectionShell from "../ui/SectionShell.astro";
---

<SectionShell
  eyebrow="Revenue and expenses"
  title="TEMPLATE: Revenue and expense headline"
  body="TEMPLATE: Direct readers to Form 990 and audited financial statements for the full functional expense breakdown."
>
  <div class="grid two">
    <div class="card">
      <h3>TEMPLATE: Revenue by source heading</h3>
      <div class="ratio-bars">
        <div class="ratio-bar"><strong>TEMPLATE: Source 1</strong><div class="bar-track"><div class="bar-fill" style="width:70%"></div></div><span>TEMPLATE</span></div>
        <div class="ratio-bar"><strong>TEMPLATE: Source 2</strong><div class="bar-track"><div class="bar-fill" style="width:20%"></div></div><span>TEMPLATE</span></div>
        <div class="ratio-bar"><strong>TEMPLATE: Source 3</strong><div class="bar-track"><div class="bar-fill" style="width:10%"></div></div><span>TEMPLATE</span></div>
      </div>
    </div>
    <div class="card">
      <h3>Expenses by category</h3>
      <p><strong>TEMPLATE: Program expense ratio from audited figures.</strong></p>
      <p>TEMPLATE: Explain where the full functional expense breakdown is published and how often it is updated.</p>
      <a class="card-link" href="/financials#form-990">Review financial disclosures</a>
    </div>
  </div>
</SectionShell>
