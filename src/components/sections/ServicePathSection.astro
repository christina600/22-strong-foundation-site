---
interface ProviderLink {
  label: string;
  href: string;
}

interface ServiceStep {
  number: string;
  heading: string;
  body: string;
  note?: string;
  provider?: ProviderLink;
}

interface ServiceOutcome {
  heading: string;
  body: string;
}

interface ServicePathContent {
  eyebrow: string;
  heading: string[];
  kicker: string;
  stepsAriaLabel: string;
  steps: ServiceStep[];
  outcome?: ServiceOutcome;
}

interface Props {
  chapter?: string;
  content: ServicePathContent;
}

const { chapter, content } = Astro.props;

// Split a step note on the "{provider}" token so the venue name renders as a
// link inline within the sentence.
const splitNote = (note: string) => {
  const [before, after = ""] = note.split("{provider}");
  return { before, after };
};
---

<section class="how-it-works story-path" id="how-it-works" data-chapter={chapter}>
  <div class="how-story-copy" data-reveal>
    <div class="eyebrow">{content.eyebrow}</div>
    <h2>{content.heading.map((line, i) => <Fragment>{i > 0 && <br />}{line}</Fragment>)}</h2>
    <p class="story-kicker">{content.kicker}</p>
  </div>

  <ol class="steps steps--path" aria-label={content.stepsAriaLabel}>
    {content.steps.map((step) => (
      <li class="step story-beat" data-reveal>
        <span class="step-number" aria-hidden="true">{step.number}</span>
        <div class="step-body">
          <h3>{step.heading}</h3>
          <p>{step.body}</p>
          {step.note && (
            <p class="step-note">
              {step.provider
                ? <Fragment>{splitNote(step.note).before}<a href={step.provider.href} target="_blank" rel="noopener noreferrer">{step.provider.label}</a>{splitNote(step.note).after}</Fragment>
                : step.note}
            </p>
          )}
        </div>
      </li>
    ))}

    {content.outcome && (
      <li class="step step--outcome" data-reveal>
        <span class="step-number step-number--outcome" aria-hidden="true"></span>
        <div class="step-body">
          <h3>{content.outcome.heading}</h3>
          <p>{content.outcome.body}</p>
        </div>
      </li>
    )}
  </ol>
</section>
