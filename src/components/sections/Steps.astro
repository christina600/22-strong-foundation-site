---
/**
 * Steps — numbered process walkthrough for Get Help page.
 * Reads phone number from site.json.
 */

import SectionShell from "../ui/SectionShell.astro";
import site from "../../content/site.json";
---

<SectionShell
  eyebrow="What to expect"
  title="TEMPLATE: Process headline"
  body="TEMPLATE: You do not have to know exactly what you need before you call."
>
  <div class="steps">
    <div class="step">
      <div><span class="step-num">01</span></div>
      <div>
        <h3>TEMPLATE: Step 1 title</h3>
        <p>Call {site.phone}. TEMPLATE: Describe who answers and what happens on the first call.</p>
      </div>
    </div>
    <div class="step">
      <div><span class="step-num">02</span></div>
      <div>
        <h3>TEMPLATE: Step 2 title</h3>
        <p>TEMPLATE: Describe the intake or assessment process, confidentiality protections, and what the advocate asks about.</p>
      </div>
    </div>
    <div class="step">
      <div><span class="step-num">03</span></div>
      <div>
        <h3>TEMPLATE: Step 3 title</h3>
        <p>TEMPLATE: Describe the next service pathway — e.g. shelter, referral, or direct services.</p>
      </div>
    </div>
    <div class="step">
      <div><span class="step-num">04</span></div>
      <div>
        <h3>TEMPLATE: Step 4 title</h3>
        <p>TEMPLATE: Describe individualized planning and client choice.</p>
      </div>
    </div>
    <div class="step">
      <div><span class="step-num">05</span></div>
      <div>
        <h3>TEMPLATE: Step 5 title</h3>
        <p>TEMPLATE: Describe ongoing support after primary services end.</p>
      </div>
    </div>
  </div>
</SectionShell>
