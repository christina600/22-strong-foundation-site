---
import { existsSync } from "node:fs";
import site from "../../content/site.json";
import StrongCircleMark from "./StrongCircleMark.astro";
import { isConfigured } from "../../utils/config";

const description =
  "Give monthly or give once. Either way, the next visit happens.";

const trustLine =
  "22STRONG Foundation is a 501(c)(3) nonprofit. EIN 99-1232582. Gifts are tax-deductible.";

const donateHref = (amount?: number) => {
  if (!isConfigured(site.donateUrl)) return "/#contact";
  if (!amount) return site.donateUrl;
  return `${site.donateUrl}?amount=${encodeURIComponent(String(amount))}&frequency=once`;
};

const circleHref = (amount?: string) => {
  if (!isConfigured(site.strongCircleUrl)) return "/#contact";
  if (!amount) return site.strongCircleUrl;
  const value = amount.replace(/[^0-9.]/g, "");
  return value
    ? `${site.strongCircleUrl}?amount=${encodeURIComponent(value)}&frequency=monthly`
    : site.strongCircleUrl;
};

// Images live in /images/support/; when a file has not been dropped in yet
// the card renders a neutral placeholder block instead.
const supportImage = (file: string) => {
  const path = "/images/support/" + file;
  return existsSync("public" + path) ? path : null;
};

const circleTiers = [
  { amount: "$22", note: "the number we're named for" },
  { amount: "$50", note: "three funded sessions a year" },
  { amount: "$100", note: "one session every other month" },
  { amount: "$190", note: "a funded session every month" },
];

const giveCards = [
  {
    heading: "Fund a session.",
    body: "$190 pays for one hands-on recovery session for a veteran or young person whose coverage ran out.",
    cta: "Give $190",
    href: donateHref(190),
    image: supportImage("give-session.jpg"),
  },
  {
    heading: "Fund a care plan.",
    body: "$850 covers an average care plan from first visit to follow-through.",
    cta: "Fund a care plan",
    href: donateHref(850),
    image: supportImage("give-careplan.jpg"),
  },
];

const faq = [
  {
    q: "Is my gift tax-deductible?",
    a: "Yes. 22STRONG Foundation is a 501(c)(3); you'll receive a receipt.",
  },
  {
    q: "Where does my money go?",
    a: null, // rendered inline below so "transparency page" can link
  },
  {
    q: "Can I cancel monthly giving?",
    a: "Anytime, no questions.",
  },
  {
    q: "Can I give in honor or memory of someone?",
    a: "Yes. Note it with your gift or through the contact form.",
  },
];
---

<main id="main" class="support-page" aria-describedby="support-description">
  <section class="support-hero" aria-labelledby="support-title">
    <div class="support-hero__inner">
      <p class="eyebrow">How to help</p>
      <h1 id="support-title">Every way to keep recovery care moving.</h1>
      <p class="lead" id="support-description">{description}</p>
    </div>
  </section>

  <section class="support-circle" id="strong-circle" aria-labelledby="circle-title">
    <div class="support-circle__copy">
      <div class="support-circle__brand">
        <p class="support-kicker">The Strong Circle</p>
        <StrongCircleMark class="support-circle__mark" size={92} />
      </div>
      <h2 id="circle-title">A membership that says yes before care stalls.</h2>
      <p class="support-circle__body">
        Circle members give monthly. That steady base is what lets 22STRONG approve a session
        the week it's needed instead of waiting on the next fundraiser. Every nine members at
        $22 a month funds a recovery session, every month, for as long as they stay.
      </p>
      <p class="support-circle__why">
        Why 22? The name comes from the widely cited “22 veterans a day” statistic and honors
        veterans lost to suicide. The $22 tier carries that symbolic number; 22STRONG itself
        funds recovery care and is not a crisis-response provider.
      </p>
      <p class="support-circle__crisis">
        If you or a veteran you know is struggling, call 988 and press 1. The Veterans
        Crisis Line answers 24/7.
      </p>
    </div>
    <blockquote class="support-circle__quote">
      <p>
        "The VA treatments are far and few between... Thankfully Dr. Vas has filled that void
        and with his treatments it has allowed me to continue being active."
      </p>
      <cite>Tom Boscamp, U.S. Army veteran</cite>
    </blockquote>
    <div class="support-circle__join" aria-label="Suggested monthly amounts">
      {circleTiers.map((tier) => (
        <a class="support-tier" href={circleHref(tier.amount)}>
          <span>{tier.amount}<small>/mo</small></span>
          <em>{tier.note}</em>
        </a>
      ))}
      <a class="pill primary support-circle__cta" href={circleHref()}>Join the Strong Circle</a>
      <p class="support-circle__footnote">
        Monthly. Cancel anytime. You'll hear from Travis himself: updates, invites, and a
        first look at what's next.
      </p>
      <p class="support-trust">{trustLine}</p>
    </div>
  </section>

  <section class="support-compare" aria-labelledby="compare-title">
    <div class="support-section-head">
      <p class="support-kicker">Give now</p>
      <h2 id="compare-title">One gift closes one gap.</h2>
    </div>
    <div class="support-card-grid">
      {giveCards.map((card) => (
        <article class="support-card">
          {card.image ? (
            <img src={card.image} alt="" loading="lazy" />
          ) : (
            <div class="support-card__placeholder" aria-hidden="true"></div>
          )}
          <div class="support-card__body">
            <h3>{card.heading}</h3>
            <p>{card.body}</p>
            <a class="pill primary support-card__cta" href={card.href}>{card.cta}</a>
            <p class="support-trust">{trustLine}</p>
          </div>
        </article>
      ))}
    </div>
    <p class="support-any">Prefer monthly? That's the Strong Circle, above.</p>
  </section>

  <section class="support-faq" aria-labelledby="faq-title">
    <h2 id="faq-title">FAQ</h2>
    <dl class="support-faq__list">
      {faq.map((item) => (
        <div class="support-faq__item">
          <dt>{item.q}</dt>
          {item.a ? (
            <dd>{item.a}</dd>
          ) : (
            <dd>
              Funded recovery sessions. How we handle money and the provider relationship is on
              the <a href="/transparency/">transparency page</a>.
            </dd>
          )}
        </div>
      ))}
    </dl>
  </section>
</main>
