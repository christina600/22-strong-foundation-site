---
import site from "../../content/site.json";
import { isConfigured } from "../../utils/config";

interface StrongCircleContent {
  heading: string;
  lead: string;
  tiersLabel?: string;
  tiers: Array<{ amount: string; note: string }>;
  joinLabel: string;
  footnote: string;
  points: Array<{ label: string; text: string }>;
  highlightedTestimonial?: {
    quote: string;
    name: string;
    title?: string;
    photo: string;
    photoAlt?: string;
  };
  /* Factual spotlight on a real member — rendered without quotation marks
     because the text is about them, not something they said. */
  memberHighlight?: {
    text: string;
    name: string;
    title?: string;
    photo: string;
    photoAlt?: string;
  };
}

interface Props {
  chapter?: string;
  strongCircle: StrongCircleContent;
  headingLevel?: "h1" | "h2";
  className?: string;
}

const { chapter, strongCircle, headingLevel = "h2", className = "" } = Astro.props;
const HeadingTag = headingLevel;
const highlighted = strongCircle.highlightedTestimonial;
const member = strongCircle.memberHighlight;

// Recurring giving routes to the dedicated Strong Circle Givebutter campaign.
// If the campaign URL is ever unset, links fall back to the contact section.
const circleReady = isConfigured(site.strongCircleUrl);
const circleHref = circleReady ? site.strongCircleUrl : "#contact";
const tierHref = (amount: string) => {
  if (!circleReady) return "#contact";
  const value = amount.replace(/[^0-9.]/g, "");
  return value
    ? `${site.strongCircleUrl}?amount=${encodeURIComponent(value)}&frequency=monthly`
    : site.strongCircleUrl;
};
---

<section class:list={["strong-circle-section", "story-commitment", className]} id="strong-circle" data-chapter={chapter}>
  <div class="strong-circle-wrap" data-reveal>
    <div class="circle-panel">
      <div class="circle-intro">
        <HeadingTag>{strongCircle.heading}</HeadingTag>
        <p class="lead">{strongCircle.lead}</p>

        <ul class="circle-points" aria-label="What membership means">
          {strongCircle.points.map((point) => (
            <li>
              {point.label && <strong>{point.label}</strong>}
              <span>{point.text}</span>
            </li>
          ))}
        </ul>

        {highlighted && (
          <figure class="circle-voice">
            <img class="circle-voice__photo" src={highlighted.photo} alt={highlighted.photoAlt ?? highlighted.name} width="72" height="72" loading="lazy" decoding="async" />
            <div class="circle-voice__body">
              <blockquote class="circle-voice__quote">{highlighted.quote}</blockquote>
              <figcaption class="circle-voice__cite">{highlighted.name}{highlighted.title ? ` · ${highlighted.title}` : ""}</figcaption>
            </div>
          </figure>
        )}

        {member && (
          <figure class="circle-voice circle-voice--member">
            <img class="circle-voice__photo" src={member.photo} alt={member.photoAlt ?? member.name} width="72" height="72" loading="lazy" decoding="async" />
            <div class="circle-voice__body">
              <p class="circle-voice__text">{member.text}</p>
              <figcaption class="circle-voice__cite">{member.name}{member.title ? ` · ${member.title}` : ""}</figcaption>
            </div>
          </figure>
        )}
      </div>

      <div class="circle-join">
        {strongCircle.tiersLabel && <span class="circle-tiers-label">{strongCircle.tiersLabel}</span>}
        <div class="circle-tiers" role="group" aria-label="Suggested monthly amounts">
          {strongCircle.tiers.map((tier) => (
            <a class="circle-tier" href={tierHref(tier.amount)}>
              <span class="circle-tier-amount">{tier.amount}<small>/mo</small></span>
              {tier.note && <span class="circle-tier-note">{tier.note}</span>}
            </a>
          ))}
        </div>
        <a class="pill primary strong-circle-trigger" href={circleHref}>{strongCircle.joinLabel}</a>
        <p class="circle-footnote">{strongCircle.footnote}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .circle-voice {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    margin-top: 22px;
    padding-top: 20px;
    border-top: 1px solid rgba(128, 128, 128, .28);
  }

  .circle-voice__photo {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    object-fit: cover;
    flex: none;
  }

  .circle-voice__quote {
    margin: 0 0 6px;
    font-size: clamp(1.3rem, 1.6vw, 1.45rem);
    font-weight: 600;
    line-height: 1.34;
  }

  .circle-voice__quote::before { content: "\201C"; }
  .circle-voice__quote::after { content: "\201D"; }

  .circle-voice__text {
    margin: 0 0 6px;
    font-size: 1.25rem;
    line-height: 1.4;
    color: rgba(255, 255, 255, .85);
  }

  .circle-voice__cite {
    font-size: 1.25rem;
    font-weight: 700;
    opacity: .78;
  }
</style>
