---
interface StrongCircleContent {
  heading: string;
  lead: string;
  tiersLabel: string;
  tiers: Array<{ amount: string; note: string }>;
  joinLabel: string;
  footnote: string;
  points: Array<{ label: string; text: string }>;
}

interface Props {
  chapter?: string;
  strongCircle: StrongCircleContent;
}

const { chapter, strongCircle } = Astro.props;
---

<section class="strong-circle-section story-commitment" id="strong-circle" data-chapter={chapter}>
  <div class="strong-circle-wrap" data-reveal>
    <div class="circle-panel">
      <div class="circle-intro">
        <h2>{strongCircle.heading}</h2>
        <p class="lead">{strongCircle.lead}</p>

        <ul class="circle-points" aria-label="What membership means">
          {strongCircle.points.map((point) => (
            <li>
              <strong>{point.label}</strong>
              <span>{point.text}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="circle-join">
        <span class="circle-tiers-label">{strongCircle.tiersLabel}</span>
        <div class="circle-tiers" role="group" aria-label="Suggested monthly amounts">
          {strongCircle.tiers.map((tier) => (
            <a class="circle-tier" href="#contact">
              <span class="circle-tier-amount">{tier.amount}<small>/mo</small></span>
              {tier.note && <span class="circle-tier-note">{tier.note}</span>}
            </a>
          ))}
        </div>
        <a class="pill primary strong-circle-trigger" href="#contact">{strongCircle.joinLabel}</a>
        <p class="circle-footnote">{strongCircle.footnote}</p>
      </div>
    </div>
  </div>
</section>
