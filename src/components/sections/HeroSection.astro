---
interface Props {
  proofline?: string[];
}

const { proofline = [] } = Astro.props;
---

<section class="hero" id="top">
  <div class="hero-inner">
    <div class="hero-copy">
      <div class="hero-mark" aria-label="22 Strong Foundation">
        <span class="hero-mark-22">22</span>
        <span class="hero-mark-strong">Strong</span>
        <span class="hero-mark-rule" aria-hidden="true"></span>
        <span class="hero-mark-foundation">Foundation</span>
      </div>
    </div>
  </div>
  {
    proofline.length > 0 && (
      <div class="hero-proofbar" aria-label="About 22 Strong Foundation">
        <ul class="hero-proofbar-list">
          {proofline.map((fact) => <li>{fact}</li>)}
        </ul>
      </div>
    )
  }
</section>
