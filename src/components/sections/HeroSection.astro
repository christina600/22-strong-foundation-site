---
interface HeroContent {
  headline: string[];
  lead: string;
  ctaLabel: string;
  taxline: string;
}

interface Props {
  hero: HeroContent;
}

const { hero } = Astro.props;
---

<section class="hero" id="top">
  <!-- Geometric morph decoration -->
  <div class="geo-morph geo-morph--hero" aria-hidden="true"></div>
  <div class="hero-inner">
    <div class="hero-copy">
      <div class="hero-mark" aria-label="22 Strong Foundation">
        <span class="hero-mark-22">22</span>
        <span class="hero-mark-strong">Strong</span>
        <span class="hero-mark-rule" aria-hidden="true"></span>
        <span class="hero-mark-foundation">Foundation</span>
      </div>
      <h1 class="hero-headline">
        {hero.headline.map((line) => <span class="hero-headline-line">{line}</span>)}
      </h1>
      <div class="hero-actions">
        <a class="pill primary hero-cta-primary" href="#donate">
          {hero.ctaLabel} <span class="hero-cta-arrow" aria-hidden="true">→</span>
        </a>
        <a class="pill hero-cta-secondary" href="#about">Our mission</a>
      </div>
    </div>
  </div>
</section>
