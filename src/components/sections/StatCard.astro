---
/**
 * StatCard — renders one stat in the showcase, switching on `stat.type`.
 *
 * Data-driven: the seven treatments live here, the content lives in
 * src/content/problem.json. Add / remove / reorder cards from the JSON
 * and the grid reflows. Class names match the originals exactly so
 * count-up.ts and scroll-reveal.ts keep working untouched.
 *
 *   figure     — single big number (counts up on scroll)
 *   ring       — donut percentage (fills on scroll); display = `${target}%`
 *   pictograph — "X in Y" with filled/empty marks (derived from filled/total)
 *   bar        — horizontal progress (fills on scroll); display = `${value}%`
 *   compare    — trend / delta between two points
 *   headline   — full-width headline statistic
 *   outcome    — forward-looking result (closes the loop)
 *
 * SINGLE SOURCE OF TRUTH: ring %, bar %, and the pictograph headline are
 * all derived from the underlying number, so there is no second copy to
 * drift. The headline/outcome figures allow <strong> via set:html so the
 * key numbers can be emphasised in otherwise free-form copy.
 */

import SourceLine from "../ui/SourceLine.astro";

const { stat } = Astro.props;

// Pictograph marks: `total` dots, the first `filled` switched on.
const marks =
  stat.type === "pictograph"
    ? Array.from({ length: stat.total }, (_, i) => i < stat.filled)
    : [];

// Compare arrow follows the direction of change.
const compareArrow = stat.direction === "down" ? "▼" : "▲";
---

{stat.type === "figure" && (
  <figure class="stat-card stat-figure">
    <p class="stat-figure-value"><strong>{stat.value}</strong></p>
    <figcaption>
      <p class="stat-card-label">{stat.label}</p>
      <SourceLine source={stat.source} />
    </figcaption>
  </figure>
)}

{stat.type === "ring" && (
  <figure class="stat-card stat-ring" style={`--target: ${stat.target};`}>
    <div class="stat-ring-viz">
      <span class="stat-ring-num">{stat.target}%</span>
    </div>
    <figcaption>
      <p class="stat-card-label">{stat.label}</p>
      <SourceLine source={stat.source} />
    </figcaption>
  </figure>
)}

{stat.type === "pictograph" && (
  <figure class="stat-card stat-pictograph">
    <p class="stat-pictograph-headline"><strong>{stat.filled}</strong> in <strong>{stat.total}</strong></p>
    <div class="stat-pictograph-marks" aria-hidden="true">
      {marks.map((on) => <span class={on ? "is-on" : undefined}></span>)}
    </div>
    <figcaption>
      <p class="stat-card-label">{stat.label}</p>
      <SourceLine source={stat.source} />
    </figcaption>
  </figure>
)}

{stat.type === "bar" && (
  <figure class="stat-card stat-bar" style={`--val: ${stat.value};`}>
    <figcaption>
      <p class="stat-card-label stat-bar-label">{stat.label}</p>
    </figcaption>
    <div class="stat-bar-track" aria-hidden="true">
      <span class="stat-bar-fill"></span>
    </div>
    <p class="stat-bar-value"><strong>{stat.value}%</strong> <span>{stat.valueLabel}</span></p>
    <SourceLine source={stat.source} />
  </figure>
)}

{stat.type === "compare" && (
  <figure class="stat-card stat-compare">
    <p class="stat-compare-delta"><span class="stat-arrow" aria-hidden="true">{compareArrow}</span> {stat.delta}</p>
    <figcaption>
      <p class="stat-card-label">{stat.label}</p>
      <p class="stat-compare-range"><span>{stat.from}</span><span class="stat-compare-line" aria-hidden="true"></span><span>{stat.to}</span></p>
      <SourceLine source={stat.source} />
    </figcaption>
  </figure>
)}

{stat.type === "headline" && (
  <figure class="stat-card stat-headline">
    <p class="stat-headline-figure" set:html={stat.figureHtml}></p>
    <figcaption>
      <p class="stat-headline-text">{stat.text}</p>
      <SourceLine source={stat.source} />
    </figcaption>
  </figure>
)}

{stat.type === "outcome" && (
  <figure class="stat-card stat-outcome">
    <p class="stat-outcome-value" set:html={stat.valueHtml}></p>
    <figcaption class="stat-outcome-body">
      <p class="stat-outcome-eyebrow">{stat.eyebrow}</p>
      <p class="stat-outcome-text">{stat.text}</p>
      <p class="stat-outcome-benchmark">{stat.benchmark}</p>
      <p class="stat-outcome-method">{stat.method}</p>
      <SourceLine source={stat.source} />
    </figcaption>
  </figure>
)}
