---
/**
 * Planning Checklist — safety planning checkbox list.
 */

import SectionShell from "../ui/SectionShell.astro";

const items = [
  "A safe contact method",
  "Important documents",
  "Emergency contacts",
  "Transportation options",
  "Medication or essentials",
  "Children, pets, or dependents",
  "Money or benefits access",
  "A safe place to go"
];
---

<SectionShell
  eyebrow="Safety planning checklist"
  title="Practical things to think through."
  body="Use this list privately and carefully. If someone may monitor your device or accounts, consider using a safer device."
>
  <div class="grid two">
    {items.map((item) => (
      <label class="card"><input type="checkbox" /> {item}</label>
    ))}
  </div>
</SectionShell>
