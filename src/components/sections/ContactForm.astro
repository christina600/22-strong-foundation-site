---
/**
 * Contact Form — non-urgent inquiry form.
 */

import SectionShell from "../ui/SectionShell.astro";
import strings from "../../content/strings/en.json";
---

<SectionShell
  eyebrow="General inquiry form"
  title="Non-urgent contact."
  body="This form is for non-urgent questions only. Do not use it for emergencies or immediate safety needs."
>
  <form id="contactFormEl" class="card">
    <!-- Honeypot: invisible to humans, bots fill it in and get caught -->
    <div class="hp" aria-hidden="true">
      <label>Leave blank<input type="text" name="website" tabindex="-1" autocomplete="off" /></label>
    </div>
    <div class="grid two">
      <label>{strings.forms.name}<br /><input required type="text" /></label>
      <label>{strings.forms.email}<br /><input required type="email" /></label>
    </div>
    <p></p>
    <label>{strings.forms.reasonForContact}<br />
      <select>
        <option>General question</option>
        <option>Donation question</option>
        <option>Volunteer question</option>
        <option>Partnership or referral</option>
        <option>Media or presentation</option>
      </select>
    </label>
    <p></p>
    <label>{strings.forms.message}<br /><textarea required rows="6"></textarea></label>
    <p style="color:var(--muted);">Do not include confidential, urgent, or highly sensitive details in this form.</p>
    <button class="btn" type="submit">{strings.forms.submitInquiry}</button>
  </form>
</SectionShell>
