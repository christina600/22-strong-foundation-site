---
/**
 * Newsletter Signup — email signup form with feature cards.
 */

import SectionShell from "../ui/SectionShell.astro";
import strings from "../../content/strings/en.json";
---

<SectionShell
  eyebrow="Stay connected"
  title="TEMPLATE: Newsletter signup headline"
  body="Once a month. No spam. Unsubscribe any time."
>
  <form id="newsletterFormEl" class="card">
    <!-- Honeypot: invisible to humans, bots fill it in and get caught -->
    <div class="hp" aria-hidden="true">
      <label>Leave blank<input type="text" name="website" tabindex="-1" autocomplete="off" /></label>
    </div>
    <div class="grid two">
      <label>{strings.forms.firstName}<br /><input type="text" /></label>
      <label>{strings.forms.emailAddress} *<br /><input required type="email" /></label>
    </div>
    <p></p>
    <button class="btn" type="submit">{strings.forms.subscribe} &rarr;</button>
    <p style="color:var(--muted);">We never share your address. You can unsubscribe at any time.</p>
  </form>
  <div class="grid four" style="margin-top:16px;">
    <div class="card"><h3>Once a month</h3><p>One email per month, no noise.</p></div>
    <div class="card"><h3>Impact stories</h3><p>Real numbers and real context from the work.</p></div>
    <div class="card"><h3>Ways to help</h3><p>Current needs, volunteer opportunities, and advocacy moments.</p></div>
    <div class="card"><h3>Unsubscribe any time</h3><p>One click. No follow-up emails asking why.</p></div>
  </div>
</SectionShell>
