---
/**
 * Breadcrumb navigation — Home > Parent > Current page.
 */

import nav from "../content/nav.json";
import strings from "../content/strings/en.json";

interface Props {
  currentPage: string;
  label: string;
}

const { currentPage, label } = Astro.props;

// Find the parent nav item for this page
function findParent(pageId: string) {
  for (const item of nav) {
    if (item.page === pageId) return { label: item.label, page: item.page };
    if (item.children?.some((c: any) => c.page === pageId)) {
      return { label: item.label, page: item.page };
    }
  }
  return null;
}

const parent = findParent(currentPage);
const showParent = parent && parent.label !== label;
---

{currentPage !== "home" && (
  <nav class="container breadcrumb" aria-label="Breadcrumb">
    <ol>
      <li><a href="/">{strings.sections.home}</a></li>
      {showParent && (
        <li><a href={`/${parent!.page}`}>{parent!.label}</a></li>
      )}
      <li aria-current="page">{label}</li>
    </ol>
  </nav>
)}
