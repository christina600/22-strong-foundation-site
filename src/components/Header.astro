---
/**
 * Site header — sticky nav bar with desktop dropdowns and mobile drawer.
 * Reads nav.json for menu structure and site.json for brand/CTA.
 */

import nav from "../content/nav.json";
import site from "../content/site.json";
import strings from "../content/strings/en.json";

interface Props {
  currentPage?: string;
}

const { currentPage = "" } = Astro.props;
---

<header class="site-header">
  <div class="header-inner">
    <a class="brand" href="/">
      <strong>{site.brandName}</strong>
      <span>{site.tagline}</span>
    </a>

    <nav class="desktop-nav" aria-label={strings.accessibility.primaryNavigation} id="desktopNav">
      {nav.map((item) => {
        if (item.children) {
          const isActive = item.page === currentPage || item.children.some((c: any) => c.page === currentPage);
          return (
            <div class="nav-item">
              <details>
                <summary class:list={["nav-summary", { active: isActive }]}>
                  {item.label} &#9662;
                </summary>
                <div class="dropdown">
                  <a href={`/${item.page === "home" ? "" : item.page}`}>
                    <strong>{item.label}</strong>
                    <span>{strings.nav.sectionOverview}</span>
                  </a>
                  {item.children.map((child: any) => (
                    <a
                      href={`/${child.page}`}
                      aria-current={child.page === currentPage ? "page" : undefined}
                    >
                      {child.label}
                      {child.desc && <span>{child.desc}</span>}
                    </a>
                  ))}
                </div>
              </details>
            </div>
          );
        }

        if (item.cta) {
          return null;
        }

        return (
          <a
            class="nav-link"
            href={`/${item.page === "home" ? "" : item.page}`}
            aria-current={item.page === currentPage ? "page" : undefined}
          >
            {item.label}
          </a>
        );
      })}
    </nav>

    <div class="header-actions">
      <a class="btn" href="/donate">{site.primaryCtaLabel}</a>
      <button
        class="btn-outline menu-toggle"
        type="button"
        id="menuToggle"
        aria-expanded="false"
        aria-controls="mobileDrawer"
      >
        {strings.nav.menu}
      </button>
    </div>
  </div>

  <nav class="mobile-drawer" id="mobileDrawer" aria-label={strings.accessibility.mobileNavigation}>
    {nav.map((item) => {
      const links = item.children || [];
      return (
        <div class="mobile-group">
          <strong>
            <a href={`/${item.page === "home" ? "" : item.page}`}>{item.label}</a>
          </strong>
          {links.map((child: any) => (
            <a href={`/${child.page}`}>{child.label}</a>
          ))}
        </div>
      );
    })}
  </nav>
</header>
<div class="scroll-progress" aria-hidden="true"></div>
