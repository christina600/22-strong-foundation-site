---
/**
 * Homepage hero — full-bleed dark photo background with text + donation widget.
 */

interface ProofItem {
  stat: string;
  label: string;
}

interface Action {
  label: string;
  page?: string;
  href?: string;
  style?: string;
}

interface Props {
  eyebrow: string;
  title: string;
  intro: string;
  actions?: Action[];
  proofStrip?: ProofItem[];
}

import strings from "../content/strings/en.json";

const { eyebrow, title, intro, actions = [], proofStrip = [] } = Astro.props;
---

<section class="hero hero-home">
  <div class="hero-bg" aria-hidden="true"></div>
  <div class="container">
    <div class="hero-home-grid">
      <div class="hero-home-text">
        <span class="eyebrow">{eyebrow}</span>
        <h1>{title}</h1>
        <p class="lead">{intro}</p>
        {actions.length > 0 && (
          <div class="hero-actions">
            {actions.map((action) => {
              const href = action.href || `/${action.page}`;
              return <a class={action.style || "btn"} href={href}>{action.label}</a>;
            })}
          </div>
        )}
        {proofStrip.length > 0 && (
          <div class="hero-proof-strip" aria-label={strings.hero.impactSnapshot}>
            {proofStrip.map((item) => (
              <span><strong>{item.stat}</strong> {item.label}</span>
            ))}
          </div>
        )}
      </div>
      <div class="hero-home-donation">
        <slot />
      </div>
    </div>
  </div>
</section>
