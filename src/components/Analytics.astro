---
/**
 * Analytics — conditionally loads a tracking script.
 *
 * Supports two providers:
 *   - "ga4"      — Google Analytics 4 (set analyticsId to your G-XXXXXXX ID)
 *   - "plausible" — Plausible Analytics (set analyticsId to your domain)
 *
 * If analyticsProvider or analyticsId is empty, nothing renders.
 * This keeps the template tracking-free until the client configures it.
 */

import site from "../content/site.json";

const provider = site.analyticsProvider?.toLowerCase() || "";
const id = site.analyticsId || "";
const enabled = provider && id;
---

{enabled && provider === "ga4" && (
  <Fragment>
    <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${id}`}></script>
    <script is:inline define:vars={{ id }}>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag("js", new Date());
      gtag("config", id);
    </script>
  </Fragment>
)}

{enabled && provider === "plausible" && (
  <script is:inline async defer
    data-domain={id}
    src="https://plausible.io/js/script.js"
  ></script>
)}
