---
/**
 * SourceLine — a stat-card citation.
 *
 * Scorpio + Capricorn: sourcing is evidence. When a real URL is present
 * the citation renders as a clickable <a> a skeptic can verify; until
 * then it's a plain caption. The unfilled URL is a "TEMPLATE:" value so
 * the content check (scripts/check-templates.mjs) flags it before deploy.
 * Set the url to empty ("") for internal data that has no public link —
 * the citation then renders as plain text, intentionally.
 */

interface Source {
  text: string;
  url?: string;
}

interface Props {
  source: Source;
}

const { source } = Astro.props;

// A link only when the URL is real — not a placeholder, not empty.
const url = source.url ?? "";
const isLink = url.length > 0 && !url.startsWith("TEMPLATE");
---

{isLink ? (
  <a
    href={url}
    class="stat-card-source"
    target="_blank"
    rel="noopener noreferrer"
  >{source.text}</a>
) : (
  <p class="stat-card-source">{source.text}</p>
)}
