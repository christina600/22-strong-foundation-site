---
/**
 * Full-Bleed Image — cinematic edge-to-edge banner with overlaid text.
 * Great for dramatic moments between card-grid sections.
 *
 * Props:
 *   eyebrow     — small label above heading
 *   title       — the big heading
 *   body        — paragraph text
 *   imageLabel  — accessible alt text for the background image
 *   imageClass  — CSS class that sets the background-image (TEMPLATE by default)
 *   dark        — if true, uses light text on dark overlay (default: true)
 */

interface Props {
  eyebrow?: string;
  title: string;
  body?: string;
  imageLabel?: string;
  imageClass?: string;
  dark?: boolean;
}

const {
  eyebrow,
  title,
  body,
  imageLabel = "TEMPLATE: Describe the image accessibly.",
  imageClass = "",
  dark = true,
} = Astro.props;
---

<section
  class:list={["full-bleed-image", { "full-bleed-dark": dark, "full-bleed-light": !dark }]}
  role="img"
  aria-label={imageLabel}
>
  <div class:list={["full-bleed-bg", imageClass]} aria-hidden="true"></div>
  <div class="full-bleed-overlay" aria-hidden="true"></div>
  <div class="container full-bleed-content">
    {eyebrow && <span class="eyebrow">{eyebrow}</span>}
    <h2>{title}</h2>
    {body && <p class="lead">{body}</p>}
    <slot />
  </div>
</section>
