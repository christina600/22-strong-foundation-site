---
/**
 * HomeBase layout — the HTML skeleton for the single-page site.
 *
 * Self-contained: provides the full SEO/head/fonts/JSON-LD/Analytics
 * setup and loads home.css. This is the site's only layout.
 *
 * Homepage scripts: donation.ts (giving widget), forms.ts (contact form),
 * site-navigation.ts (anchor handling), home-reveal.ts (scrollytelling),
 * lazy-video.ts, and testimonial-reel.ts.
 * The `js` class is added inline before paint so the reveal start state
 * only applies when JS can finish the animation.
 *
 * Props:
 *   title        — the browser tab title (required)
 *   description  — meta description for search engines
 */

import { getImage } from "astro:assets";
import site from "../content/site.json";
import Analytics from "../components/Analytics.astro";
import strings from "../content/strings/en.json";
import { isConfigured } from "../utils/config";
import { heroBattleRopes } from "../assets/images";
import "../styles/home.css";

// Generate optimized hero image URL for preload
const heroImage = await getImage({
  src: heroBattleRopes,
  format: "webp",
  quality: 82,
});

// JSON-LD Organization structured data for rich search results.
// Only emit fields that hold real values.
const jsonLd: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "NonprofitOrganization",
  "name": site.orgName,
  "description": site.descriptor,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": site.address
  },
  "taxID": site.ein,
  "nonprofitStatus": site.taxStatus,
  "areaServed": site.serviceArea
};
if (isConfigured(site.siteUrl)) jsonLd.url = site.siteUrl;
if (isConfigured(site.email)) jsonLd.email = site.email;
if (isConfigured(site.phone)) jsonLd.telephone = site.phone;

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const pageTitle = `${title} | ${site.orgName}`;
const metaDesc = description || site.descriptor;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="referrer" content="no-referrer" />

  <title>{pageTitle}</title>
  <meta name="description" content={metaDesc} />

  <!-- Social sharing -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={metaDesc} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content={site.orgName} />
  <meta property="og:url" content={Astro.url.href} />
  <meta property="og:locale" content="en_US" />

  <!-- Canonical URL -->
  <link rel="canonical" href={Astro.url.href} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" />
  
  <!-- Apple Touch Icon (uses SVG as fallback) -->
  <link rel="apple-touch-icon" href="/favicon.svg" />
  <meta name="apple-mobile-web-app-title" content="22 Strong" />

  <!-- Preload hero background image — CSS url() can't be natively lazy,
       so this hint lets the browser start the fetch early with high priority.
       Uses Astro-optimized WebP for better compression. -->
  <link rel="preload" as="image" href={heroImage.src} fetchpriority="high" />

  <!-- Gate the scrollytelling start state on JS so non-JS users see all -->
  <script is:inline>document.documentElement.classList.add('js');</script>

  <meta name="generator" content={Astro.generator} />

  <!-- Organization structured data for rich search results -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd).replace(/</g, "\\u003c")} />

  <!-- Analytics: only loads if configured in site.json -->
  <Analytics />
</head>
<body>
  <a class="skip-link" href="#main">{strings.nav.skipToContent}</a>

  <slot />

  <!-- Homepage interaction scripts -->
  <script>
    import "../scripts/donation.ts";
    import "../scripts/forms.ts";
    import "../scripts/site-navigation.ts";
    import "../scripts/home-reveal.ts";
    import "../scripts/lazy-video.ts";
    import "../scripts/testimonial-reel.ts";
    import "../scripts/giving-invite.ts";
  </script>
</body>
</html>
