---
/**
 * Program detail layout — like Page.astro, but uses the photo-forward
 * ProgramHero (which morphs from the clicked program card) instead of
 * the standard text hero.
 *
 * Props:
 *   slug        — the program's page slug (matches programs.json `page`)
 *   description — meta description for search engines
 *   ogImage     — social sharing image URL
 */

import Base from "./Base.astro";
import Header from "../components/Header.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import Footer from "../components/Footer.astro";
import ProgramHero from "../components/ProgramHero.astro";
import { getProgram } from "../lib/programs";

interface Props {
  slug: string;
  description?: string;
  ogImage?: string;
}

const { slug, description, ogImage } = Astro.props;
const program = getProgram(slug);
if (!program) {
  throw new Error(`ProgramPage: no program found for slug "${slug}" in programs.json`);
}

// Gemini (the two faces): the social-card crawler should see the program's
// own photo. Fall back to the program image when no explicit ogImage is set,
// so a shared link previews with the right picture once images are added.
const socialImage = ogImage || program.image || undefined;
---

<Base title={program.title} description={description} ogImage={socialImage}>
  <Header currentPage="programs" />
  <Breadcrumb currentPage="programs" label={program.title} />
  <ProgramHero program={program} />

  <main id="main" tabindex="-1">
    <slot />
  </main>

  <Footer />
</Base>
